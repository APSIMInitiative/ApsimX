                            "",
                            "        [Description(\"fert_code\")]",
                            "        public string fert_code { get; set; }",
                            "",
                            "        [EventSubscribe(\"StartOfSimulation\")]",
                            "        private void OnSimulationCommencing(object sender, EventArgs e)",
                            "        {",
                            "            /*",
                            "                location = '[location]' !'Condobolin'",
                            "irrig_treat = '[irrig_treat]' ! 'dry'",
                            "trial_code = '[trial_code]' ! 'CSTB16COND2'",
                            "minn_tot = 0",
                            "TOS = [TOS] !'1'",
                            "dens_trt = 45",
                            "exp = '1b'",
                            "fert_treat = '[fert_code]'",
                            "            */",
                            "        }",
                            "    }",
                            "}"
