                {
                  "$type": "Models.Manager, Models",
                  "CodeArray": [
                    "using APSIM.Core;",
                    "using Models.PMF;",
                    "using Models.Core;",
                    "using System;",
                    "using Models.Soils;",
                    "namespace Models",
                    "{",
                    "    [Serializable] ",
                    "    public class Script : Model, IStructureDependency",
                    "    {",
                    "        [Link] private Clock Clock;",
                    "        [Link] private Fertiliser Fertiliser;",
                    "        [Link] private Summary Summary;",
                    "        [Link] private Plant Canola;",
                    "        public IStructure Structure { private get; set; }",
                    " ",
                    "        private bool hasFertilised = false;",
                    "",
                    "        [Description(\"Fertilise once crop reaches stage:\")]",
                    "        public double Stage { get; set; }",
                    "",
                    "        [Description(\"Type of fertiliser to apply? \")] ",
                    "        [Display(Type = DisplayType.FertiliserType)]public string FertiliserType { get; set; }",
                    "",
                    "        [Description(\"Amount of fertiliser to be applied (kg/ha)\")] ",
                    "        public double Amount { get; set; }",
                    "     ",
                    "",
                    "        ",
                    "",
                    "        [EventSubscribe(\"DoManagement\")] ",
                    "        private void OnDoManagement(object sender, EventArgs e)",
                    "        { ",
                    "            double zadok = (double)Structure.GetObject(\"Phenology.Stage\", relativeTo: Canola).Value; ",
                    " ",
                    "            if (zadok >= Stage && !hasFertilised)",
                    "            { ",
                    "                Summary.WriteMessage(this, \"Fertilising!!\", MessageType.Diagnostic); ",
                    "                Fertiliser.Apply(amount: Amount, type: FertiliserType);",
                    "                hasFertilised = true; ",
                    "            } ",
                    "        }",
                    "",
                    "        [EventSubscribe(\"Sowing\")]",
                    "        private void OnSowing(object sender, EventArgs e)",
                    "        {",
                    "            hasFertilised = false;",
                    "        }",
                    "    }",
                    "}"
                  ],
                  "Parameters": [
                    {
                      "Key": "Stage",
                      "Value": "4"
                    },
                    {
                      "Key": "FertiliserType",
                      "Value": "NO3N"
                    },
                    {
                      "Key": "Amount",
                      "Value": "100"
