                {
                  "$type": "Models.Manager, Models",
                  "CodeArray": [
                    "using APSIM.Shared.Utilities;",
                    "using Models.Utilities;",
                    "using Models.Soils;",
                    "using Models.PMF;",
                    "using Models.Core;",
                    "using System;",
                    "using System.Linq;",
                    "",
                    "namespace Models",
                    "{",
                    "    [Serializable] ",
                    "    public class Script : Model",
                    "    {",
                    "        [Link] Clock Clock;",
                    "        [Link] Irrigation Irrigation;",
                    "    ",
                    "        [Description(\"Dates to Irrigate on\")]",
                    "        public string[] Dates { get; set; }",
                    "        ",
                    "        [Description(\"Amount to Irrigate on each Date\")]",
                    "        public double[] Amounts { get; set; }",
                    "        ",
                    "        [Description(\"Depth in the soil to apply the  irrigation (mm)\")] ",
                    "        public double Depth { get; set; }",
                    "        ",
                    "        [Description(\"Efficiency of irrigation (0-1)\")] ",
                    "        public double Efficiency { get; set; }",
                    "        ",
                    "        [Description(\"Will the irrigation runoff?\")] ",
                    "        public bool WillRunoff { get; set; }",
                    "        ",
                    "        [EventSubscribe(\"DoManagement\")]",
                    "        private void OnDoManagement(object sender, EventArgs e)",
                    "        {",
                    "            if (Dates != null && Amounts != null)",
                    "            {",
                    "                for(int i = 0; i < Dates.Length; i++)",
                    "                {",
                    "                    if (DateUtilities.DatesAreEqual(Dates[i], Clock.Today))",
                    "                        Irrigation.Apply(amount: Amounts[i], depth: Depth, efficiency: Efficiency, willRunoff: WillRunoff);",
                    "                }",
                    "            }",
                    "        }",
                    "    }",
                    "}",
                    "       "
                  ],
                  "Parameters": [
                    {
                      "Key": "Dates",
                      "Value": ""
                    },
                    {
                      "Key": "Amounts",
                      "Value": ""
                    },
                    {
                      "Key": "Depth",
                      "Value": "0"
                    },
                    {
                      "Key": "Efficiency",
                      "Value": "1"
                    },
                    {
                      "Key": "WillRunoff",
                      "Value": "False"
                    }
                  ],
                  "Name": "Irrigate",
                  "ResourceName": null,
                  "Children": [],
                  "Enabled": true,
                  "ReadOnly": false
                },
