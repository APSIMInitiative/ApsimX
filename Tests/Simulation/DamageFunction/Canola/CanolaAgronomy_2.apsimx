                      "$type": "Models.Manager, Models",
                      "CodeArray": [
                        "using Models.Soils;",
                        "using System;",
                        "using Models.Core;",
                        "using Models.PMF;",
                        "namespace Models",
                        "{",
                        "    [Serializable]",
                        "    public class Script : Model",
                        "    {",
                        "        [Link] Clock Clock;",
                        "        [Link] Fertiliser Fertiliser;",
