                        },
                        {
                          "$type": "Models.Manager, Models",
                          "CodeArray": [
                            "using Models.Soils.Nutrients;",
                            "using System;",
                            "using Models.Soils;",
                            "using Models.Core;",
                            "using Models.PMF;",
                            "using APSIM.Shared.Utilities;",
                            "namespace Models",
                            "{",
                            "    [Serializable]",
                            "    public class Script : Model",
                            "    {",
                            "        [Link] Clock Clock;",
                            "        [Link] Fertiliser Fertiliser;",
                            "        [Link] INutrient nutrient;",
                            "        [Link] Summary sum;",
                            "        ",
                            "        [Separator(\"A component to apply fertiliser on one or more dates on every year of the simulation\")]",
                            "",
                            "        [Description(\"Type of fertiliser to apply? \")] ",
                            "        [Display(Type = DisplayType.FertiliserType)]public string FertiliserType { get; set; }",
                            "",
                            "        [Description(\"Enter the fertilisation dates as dd-mmm with comma separation (any year information entered will be ignored): \")] ",
                            "        public string[] FertiliserDates { get; set; } ",
                            "",
                            "        [Description(\"Don't add fertiliser if N in top 2 layers exceeds (kg/ha) : \")]",
                            "        public double fert_criteria { get; set; }",
                            "",
                            "        [Description(\"Amount of fertiliser to be applied each time (kg /ha)\")] ",
                            "        public double Amount { get; set; }",
                            "",
                            "        [Description(\"Depth (mm)\")] public double FertiliserDepth { get; set; }",
                            "        ",
                            "        [EventSubscribe(\"DoManagement\")]",
                            "        private void OnDoManagement(object sender, EventArgs e)",
                            "        {",
                            "            foreach (string ddMMM in FertiliserDates)",
                            "            {",
                            "                if (DateUtilities.DatesEqual(ddMMM, Clock.Today))",
                            "                {",
                            "                    double soil_N = nutrient.NH4.kgha[0] + nutrient.NO3.kgha[0] + nutrient.NH4.kgha[1] + nutrient.NO3.kgha[1];",
                            "                    if (soil_N <= fert_criteria) ",
                            "                         Fertiliser.Apply(amount: Amount, type: FertiliserType, depth: FertiliserDepth);",
                            "                    else",
                            "                        sum.WriteMessage(this, \"No fertilising as top two layers have \" + soil_N.ToString() + \"kg/ha N\", MessageType.Diagnostic);",
                            "                }",
                            "            }",
                            "        }",
                            "    }",
                            "}"
                          ],
                          "Parameters": [
                            {
                              "Key": "FertiliserType",
                              "Value": "UreaN"
                            },
                            {
                              "Key": "FertiliserDates",
                              "Value": "8-Jul"
                            },
                            {
                              "Key": "fert_criteria",
                              "Value": "1000"
                            },
                            {
                              "Key": "Amount",
                              "Value": "50"
                            },
                            {
                              "Key": "FertiliserDepth",
                              "Value": "0"
                            }
                          ],
                          "Name": "Fertilise1",
                          "ResourceName": null,
                          "Children": [],
                          "Enabled": true,
                          "ReadOnly": false
                        },
