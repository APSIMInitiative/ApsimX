                        {
                          "$type": "Models.Manager, Models",
                          "CodeArray": [
                            "using APSIM.Shared.Utilities;",
                            "using Models.Utilities;",
                            "using Models.Soils;",
                            "using Models.PMF;",
                            "using Models.Core;",
                            "using System;",
                            "",
                            "namespace Models",
                            "{",
                            "    [Serializable]",
                            "    public class Script : Model",
                            "    {",
                            "        [Link] Clock Clock;",
                            "        [Link] Fertiliser Fertiliser;",
                            "        [Link] Summary Summary;",
                            "        [Link] Soil Soil;",
                            "        ",
                            "        [Description(\"Crop\")]",
                            "        public IPlant Crop { get; set; }",
                            "",
                            "        [Description(\"Sowing date (d-mmm)\")]",
                            "        public string SowDate { get; set; }",
                            "",
                            "        [Display(Type = DisplayType.CultivarName)]",
                            "        [Description(\"Cultivar to be sown\")]",
                            "        public string CultivarName { get; set; }",
                            "",
                            "        [Description(\"Sowing depth (mm)\")]",
                            "        public double SowingDepth { get; set; }",
                            "",
                            "        [Description(\"Row spacing (mm)\")]",
                            "        public double RowSpacing { get; set; }",
                            "",
                            "        [Description(\"Plant population (/m2)\")]",
                            "        public double Population { get; set; }",
                            "",
                            "        [EventSubscribe(\"DoManagement\")]",
                            "        private void OnDoManagement(object sender, EventArgs e)",
                            "        {",
                            "            if (DateUtilities.WithinDates(SowDate, Clock.Today, SowDate))",
                            "            {",
                            "                Crop.Sow(population: Population, cultivar: CultivarName, depth: SowingDepth, rowSpacing: RowSpacing);    ",
                            "            }",
                            "        }",
                            "    }",
                            "}"
                          ],
                          "Parameters": [
                            {
                              "Key": "Crop",
                              "Value": "[Maize]"
                            },
                            {
                              "Key": "SowDate",
                              "Value": "13-May"
                            },
                            {
                              "Key": "CultivarName",
                              "Value": "P1108Q"
                            },
                            {
                              "Key": "SowingDepth",
                              "Value": "70"
                            },
                            {
                              "Key": "RowSpacing",
                              "Value": "760"
                            },
                            {
                              "Key": "Population",
                              "Value": "8.6"
                            }
                          ],
                          "Name": "Sow on a fixed date",
                          "ResourceName": null,
                          "Children": [],
                          "Enabled": true,
                          "ReadOnly": false
                        },
                        {
                          "$type": "Models.Manager, Models",
                          "CodeArray": [
                            "using APSIM.Shared.Utilities;",
                            "using Models.Utilities;",
                            "using Models.Soils;",
                            "using Models.PMF;",
                            "using Models.Core;",
                            "using System;",
                            "using System.Linq;",
                            "",
                            "namespace Models",
                            "{",
                            "    [Serializable] ",
                            "    public class Script : Model",
                            "    {",
                            "        [Description(\"Crop\")]",
                            "        public IPlant Crop { get; set; }",
                            "        ",
                            "        [EventSubscribe(\"DoManagement\")]",
                            "        private void OnDoManagement(object sender, EventArgs e)",
                            "        {",
                            "            if (Crop.IsReadyForHarvesting)",
                            "            {",
                            "                Crop.Harvest();",
                            "                Crop.EndCrop();",
                            "            }",
                            "        }",
                            "    }",
                            "}",
                            "       "
                          ],
                          "Parameters": [
                            {
                              "Key": "Crop",
                              "Value": "[Maize]"
                            }
                          ],
                          "Name": "Harvesting",
                          "ResourceName": null,
                          "Children": [],
                          "Enabled": true,
                          "ReadOnly": false
                        },
                        {
                          "$type": "Models.Report, Models",
                          "VariableNames": [
                            "[Clock].Today",
                            "[Clock].Today.DayOfYear",
                            "[Maize].DaysAfterSowing",
                            "[Maize].Phenology.CurrentStageName",
                            "[Maize].Phenology.Stage",
                            "[Maize].Phenology.FloweringDAS as DTF ",
                            "[Maize].Phenology.MaturityDAS  as DTM",
                            "",
                            "[Maize].AboveGround.Wt",
                            "[Maize].Leaf.LAI",
                            "[Maize].Grain.Wt",
                            "[Maize].Grain.N",
                            "[Maize].Grain.Size",
                            "[Maize].Grain.Number",
                            "[Maize].Leaf.Live.Wt",
                            "[Maize].Leaf.Live.N",
                            "[Maize].Leaf.Dead.Wt",
                            "[Maize].Leaf.Dead.N",
                            "[Maize].Leaf.Wt",
                            "[Maize].Stem.Wt",
                            "[Maize].Stem.N",
                            "[Structure].TotalStemPopn",
                            "[Maize].Cob.Wt",
                            "[Maize].Cob.N",
                            "[Maize].Cob.CobNumber",
                            "Divide([Maize].Grain.Number,[Maize].Cob.CobNumber) as GrainsPerCob",
                            "[Maize].Cob.Wt + [Maize].Grain.Wt as EarWt",
                            "[Maize].Cob.CobSize",
                            "[Maize].Grain.Number",
                            "[Maize].Root.Depth",
                            "[Maize].Root.Live.Wt",
                            "[Maize].Root.Wt"
                          ],
                          "EventNames": [
                            "[Clock].DoReport"
                          ],
                          "GroupByVariableName": null,
                          "Name": "ReportWt",
