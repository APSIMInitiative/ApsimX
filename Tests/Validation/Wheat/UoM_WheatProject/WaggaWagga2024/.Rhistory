df_stg %>%
dplyr::select(DateReached, Cultivar, StageName) %>%
dplyr::rename(Date = DateReached) %>%
dplyr::inner_join(df_nm, by = "Cultivar") %>%
# --- CONDITIONAL MUTATE ---
dplyr::mutate(
# 1. Create the new dynamic column (!!vr_nm)
!!vr_nm := dplyr::case_when(
# Condition 1: If StageName contains "Emerging", assign 3
grepl("Emerging", StageName, ignore.case = TRUE) ~ 3,
# Condition 2: If StageName contains "StemElongating", assign 5
grepl("StemElongating", StageName, ignore.case = TRUE) ~ 5,
# Condition 3: If StageName contains "Flowering", assign 8
grepl("Flowering", StageName, ignore.case = TRUE) ~ 8,
# Default Case: If none of the above match, assign "NoMatch"
# TRUE ~ is the equivalent of the ELSE clause
TRUE ~ "NoMatch"
)
)
