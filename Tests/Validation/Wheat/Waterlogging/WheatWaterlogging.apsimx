                {
                  "$type": "Models.Manager, Models",
                  "CodeArray": [
                    "using System;",
                    "using Models.Core;",
                    "using Models.Interfaces;",
                    "using Models.PMF;",
                    "using Models.Soils;",
                    "using APSIM.Shared.Utilities;",
                    "",
                    "namespace Models",
                    "{",
                    "    [Serializable]",
                    "    public class Script : Model",
                    "    {",
                    "        [Link] Clock clock;",
                    "        [Link] IClock Clock;",
                    "        [Link] ISummary Summary;",
                    "        [Link] Swim3 swim;",
                    "        [Link] SwimSubsurfaceDrain ssd;",
                    "",
                    "        [EventSubscribe(\"DoManagement\")]",
                    "        private void DoDailyCalculations(object sender, EventArgs e)",
                    "        {",
                    "            TimeSpan span = clock.EndDate - clock.StartDate;",
                    "            double simulation_days = Clock.FractionComplete * span.TotalDays;",
                    "            ",
                    "            if (simulation_days <= 247) {",
                    "                // we are in the period prior to the water table treatment",
                    "                // Water is flowing in to keep water table at 20cm and outflow tap is open",
                    "                swim.SetLowerBCForGivenPotential(15); //bbc_potential = 15;",
                    "                ",
                    "                // subsurface_drain_open = true",
                    "            }",
                    "",
                    "            if (simulation_days >= 248 && simulation_days < 262) {",
                    "                // we are in the period after to the water table treatment but prior to anthesis",
                    "                // Water is flowing in to keep water table at 20cm and outflow tap is open",
                    "                swim.SetLowerBCForGivenPotential(120); //bbc_potential = 15;",
                    "                //subsurface_drain_open = true",
                    "            }",
                    "",
                    "            if (simulation_days >= 262 && simulation_days < 300) {",
                    "                // we are in the period after to the water table treatment but prior to anthesis",
                    "                // Water is flowing in to keep water table at 20cm and outflow tap is open",
                    "                swim.SetLowerBCForGivenPotential(15); //bbc_potential = 15;",
                    "                //subsurface_drain_open = true",
                    "            }",
                    "",
                    "",
                    "            if (simulation_days >= 300 && simulation_days < 530) {",
                    "                // we are in the period after anthesis",
                    "                // No water flowing in and outflow tap is open",
                    "                swim.SetLowerBCForGradient(-1); //bbc_gradient = -1;",
                    "                //subsurface_drain_open = true",
                    "            }",
                    "   ",
                    "               if (simulation_days >= 624 && simulation_days < 638) {",
                    "                // we are in the period after to the water table treatment but prior to anthesis",
                    "                // Water is flowing in to keep water table at 20cm and outflow tap is open",
                    "                swim.SetLowerBCForGivenPotential(120); //bbc_potential = 15;",
                    "                //subsurface_drain_open = true",
                    "            }",
                    "            ",
                    "               if (simulation_days >= 638 && simulation_days < 660) {",
                    "                // we are in the period after to the water table treatment but prior to anthesis",
                    "                // Water is flowing in to keep water table at 20cm and outflow tap is open",
                    "                swim.SetLowerBCForGivenPotential(15); //bbc_potential = 15;",
                    "                //subsurface_drain_open = true",
                    "            }        ",
                    "            ",
                    "               if (simulation_days >= 661) {",
                    "                // we are in the period after anthesis",
                    "                // No water flowing in and outflow tap is open",
                    "                swim.SetLowerBCForGradient(-1); //bbc_gradient = -1;",
                    "                //subsurface_drain_open = true",
                    "            }",
                    "        ",
                    "        }",
                    "    }",
                    "}"
                  ],
                  "Parameters": [],
                  "Name": "Watertable depth",
                  "ResourceName": null,
                  "Children": [],
                  "Enabled": true,
                  "ReadOnly": false
                },
