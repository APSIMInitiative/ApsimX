                      "NaturalVegetation": null,
                      "ApsoilNumber": "1069",
                      "Latitude": -24.906093,
                      "Longitude": 152.401241,
                      "LocationAccuracy": "Regional Soil Type",
                      "YearOfSampling": "0",
                      "DataSource": null,
                      "Comments": "Sandy loam - Sandy-Loam surface,Sandy-clay subsoil",
                      "Name": "Soil",
                      "ResourceName": null,
                      "Children": [
                        {
                          "$type": "Models.Soils.Physical, Models",
                          "Thickness": [
                            200.0,
