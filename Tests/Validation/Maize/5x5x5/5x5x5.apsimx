                            "[Clock].Today",
                            "[Clock].Today.Year",
                            "[Maize].Phenology.CurrentStageName",
                            "",
                            "[Maize].Grain.Wt * 0.159/0.85 as Yield_buac",
                            "[Maize].Grain.Wt",
                            "",
                            "[Maize].Phenology.EmergenceDAS",
                            "[Maize].Phenology.FloweringDAS",
                            "[Maize].Phenology.MaturityDAS",
                            "[Maize].DaysAfterSowing",
                            "[Maize].Population",
