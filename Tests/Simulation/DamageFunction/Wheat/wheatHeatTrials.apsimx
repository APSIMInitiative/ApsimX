                {
                  "$type": "Models.Manager, Models",
                  "CodeArray": [
                    "using Models.Soils.Nutrients;",
                    "using System;",
                    "using Models.Core;",
                    "using Models.PMF;",
                    "using Models.Soils;",
                    "using Models.Soils.Nutrients;",
                    "using Models.Utilities;",
                    "using APSIM.Shared.Utilities;",
                    "",
                    "namespace Models",
                    "{",
                    "    [Serializable]",
                    "    public class Script : Model",
                    "    {",
                    "        [Link(ByName = true)] Plant Wheat;",
                    "        [Link] Clock Clock;",
                    "        ",
                    "        [Description(\"Must Harvest (d-mmm)\")]",
                    "        public string HarvestDate { get; set; }",
                    "",
                    "        [EventSubscribe(\"DoManagement\")]",
                    "        private void OnDoManagement(object sender, EventArgs e)",
                    "        {",
                    "            if (Wheat.IsReadyForHarvesting)",
                    "            {",
                    "               Wheat.Harvest();",
                    "               Wheat.EndCrop();    ",
                    "            }",
                    "            else if ((Wheat.IsAlive) && (DateUtilities.WithinDates(HarvestDate, Clock.Today, HarvestDate)))",
                    "                        {",
                    "               Wheat.Harvest();",
                    "               Wheat.EndCrop();    ",
                    "            }",
                    "        ",
                    "        }",
                    "        ",
                    "    }",
                    "}"
                  ],
                  "Parameters": [
                    {
                      "Key": "HarvestDate",
                      "Value": "31-dec"
