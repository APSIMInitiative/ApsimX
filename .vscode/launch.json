{
    // Use IntelliSense to learn about possible attributes.
    // Hover to view descriptions of existing attributes.
    // For more information, visit: https://go.microsoft.com/fwlink/?linkid=830387
    "version": "0.2.0",
    "configurations": [

        {
            "name": "Apsim NG: Debug",
            "type": "coreclr",
            "request": "launch",
            "preLaunchTask": "Build Debug",
            "program": "${workspaceFolder}/bin/Debug/net8.0/ApsimNG.dll",
            "cwd": "${workspaceFolder}",
            "console": "integratedTerminal",
            "justMyCode": false,
            "requireExactSource": false,
            "logging": {
                "moduleLoad": false,
                "threadExit": false
            },
            "symbolOptions": {
                "searchMicrosoftSymbolServer": false
            },
            "presentation": {
                "hidden": false,
                "group": "APSIM UI",
                "order": 1,
                "focus": true
            }
        },
        {
            "name": "Apsim NG: Release",
            "type": "coreclr",
            "request": "launch",
            "preLaunchTask": "Build Release",
            "program": "${workspaceFolder}/bin/Release/net8.0/ApsimNG.dll",
            "cwd": "${workspaceFolder}",
            "requireExactSource": true,
            "symbolOptions": {
                "searchMicrosoftSymbolServer": false
            },
            "presentation": {
                "hidden": false,
                "group": "APSIM UI",
                "order": 2
            }
        },
        {
            "name": "APSIM.Cli: Debug",
            "type": "coreclr",
            "request": "launch",
            "preLaunchTask": "Clean Debug",
            "program": "${workspaceFolder}/bin/Debug/net8.0/apsim.dll",
            "args": [
                "document",
                "${workspaceFolder}/Examples/Wheat.apsimx"
            ],
            "cwd": "${workspaceFolder}",
            "console": "internalConsole",
            "stopAtEntry": false,
            "presentation": {
                "hidden": true,
                "group": "APSIM CLI",
                "order": 1
            }
        },
        {
            "name": "Models: Debug",
            "type": "coreclr",
            "request": "launch",
            "preLaunchTask": "Clean Debug",
            "program": "${workspaceFolder}/bin/Debug/net8.0/Models.exe",
            "args": [
                "C:\\Work\\Repos\\APSIMInitiative\\ApsimX\\Examples\\Stock.apsimx"
            ],
            "cwd": "${workspaceFolder}",
            "console": "internalConsole",
            "stopAtEntry": false,
            "presentation": {
                "hidden": false,
                "group": "Models",
                "order": 1
            }
        },
        {
            "name": "APSIM Server: Debug",
            "type": "coreclr",
            "request": "launch",
            "preLaunchTask": "Clean Debug",
            "program": "${workspaceFolder}/bin/Debug/net8.0/ApsimZMQServer.dll",
            "args": [
                "-v", "-a", "127.0.0.1",
                "-p", "57220", "-P", "interactive",
                "-f", "${workspaceFolder}/Tests/Simulation/ZMQ-Sync/ZMQ-sync.apsimx"
            ],
            "cwd": "${workspaceFolder}",
            "console": "internalConsole",
            "stopAtEntry": false,
            "presentation": {
                "hidden": false,
                "group": "APSIM Server",
                "order": 4
            }
        },
        {
            "name": ".NET Core Attach",
            "type": "coreclr",
            "request": "attach",
            "processId": "${command:pickProcess}",
            "presentation": {
                "hidden": true,
                "group": "attach",
                "order": 1
            }
        },
        {
            "name": "Autodocs",
            "type": "coreclr",
            "request": "launch",
            "preLaunchTask": "Build Debug",
            "program": "${workspaceFolder}/bin/Debug/net8.0/APSIM.Documentation.dll",
            "cwd": "${workspaceFolder}",
            "console": "internalConsole",
            "stopAtEntry": false,
            "justMyCode": false,
            "requireExactSource": false,
            "logging": {
                "moduleLoad": false,
                "threadExit": false
            },
            "symbolOptions": {
                "searchMicrosoftSymbolServer": false
            },
            "presentation": {
                "hidden": false,
                "group": "Documentation",
                "order": 1
            }
        },
        {
            "name": "Apsim.Workflow: Debug",
            "type": "coreclr",
            "request": "launch",
            "program": "${workspaceFolder}/bin/Debug/net8.0/Apsim.Workflow.dll",
            "preLaunchTask": "Build Debug",
            "cwd": "${workspaceFolder}",
            "console": "integratedTerminal",
            "justMyCode": false,
            "requireExactSource": false,
            "logging": {
                "moduleLoad": false,
                "threadExit": false
            },
            "args": [
                "-d",
                "C:/Users/RIC394/source/repos/ApsimX/Tests/Validation/Canola",
                // "C:/Users/RIC394/source/repos/ApsimX/Tests/Validation/Maize",
                "-v",
                // "-l"
            ],
            "presentation": {
                "hidden": false,
                "group": "Workflow",
                "order": 1,
            }

        },
        {
            "name": "Apsim.Workflow: Splitter",
            "type": "coreclr",
            "request": "launch",
            "program": "${workspaceFolder}/bin/Debug/net8.0/Apsim.Workflow.dll",
            "preLaunchTask": "Build Debug",
            "cwd": "${workspaceFolder}",
            "console": "integratedTerminal",
            "justMyCode": false,
            "requireExactSource": false,
            "logging": {
                "moduleLoad": false,
                "threadExit": false
            },
            "symbolOptions": {
                "searchMicrosoftSymbolServer": false
            },
            "args": [
                "-d",
                "${workspaceFolder}/Tests/Validation/Eucalyptus/Eucalyptus.apsimx",
                "-s",
                "${workspaceFolder}/Tests/Validation/Eucalyptus/split.json"
            ],
            "presentation": {
                "hidden": false,
                "group": "Workflow",
                "order": 10
            }
        },
        {
            "name": "Apsim.Workflow: Sim Count",
            "type": "coreclr",
            "request": "launch",
            "program": "${workspaceFolder}/bin/Debug/net8.0/Apsim.Workflow.dll",
            "preLaunchTask": "Build Debug",
            "cwd": "${workspaceFolder}",
            "console": "integratedTerminal",
            "justMyCode": false,
            "requireExactSource": false,
            "logging": {
                "moduleLoad": false,
                "threadExit": false
            },
            "symbolOptions": {
                "searchMicrosoftSymbolServer": false
            },
            "args": [
                "--sim-count",
                ""
            ],
            "presentation": {
                "hidden": false,
                "group": "Workflow",
                "order": 11
            }
        },
        {
            "name": "Apsim.Workflow: List directories",
            "type": "coreclr",
            "request": "launch",
            "program": "${workspaceFolder}/bin/Debug/net8.0/Apsim.Workflow.dll",
            "preLaunchTask": "Build Debug",
            "cwd": "${workspaceFolder}",
            "console": "integratedTerminal",
            "justMyCode": false,
            "requireExactSource": false,
            "logging": {
                "moduleLoad": false,
                "threadExit": false
            },
            "symbolOptions": {
                "searchMicrosoftSymbolServer": false
            },
            "args": [
                "-l",
                ""
            ],
            "presentation": {
                "hidden": false,
                "group": "Workflow",
                "order": 4
            }
        },
        {
            "name": "Generate Single: APSIM.Documentation",
            "type": "coreclr",
            "request": "launch",
            "program": "${workspaceFolder}/bin/Debug/net8.0/APSIM.Documentation.dll",
            "preLaunchTask": "Build Debug",
            "cwd": "${workspaceFolder}",
            "console": "integratedTerminal",
            "justMyCode": false,
            "requireExactSource": false,
            "logging": {
                "moduleLoad": false,
                "threadExit": false
            },
            "symbolOptions": {
                "searchMicrosoftSymbolServer": false
            },
            // Note: the first argument is the name of the simulation 
            // to document or the exact name of a APSIM Model.
            // The second argument is the output directory. 
            // The third argument is whether to include images in 
            // the generated documentation this defaults to false if not
            //provided.
            "args": [
                "Waterlogging",
                "${workspaceFolder}/GeneratedDocumentation",
                "true"
            ],
            "presentation": {
                "hidden": false,
                "group": "Documentation",
                "order": 5
            }
        }
    ]
}
