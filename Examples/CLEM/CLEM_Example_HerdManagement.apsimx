    {
      "$type": "Models.Core.Simulation, Models",
      "Name": "Increase breeders",
      "ResourceName": null,
      "Children": [
        {
          "$type": "Models.Memo, Models",
          "Text": "Herd management example\n# Increase female breeder numbers from breeding and purchases\n\n## Activity\nActivities.Manage herd.Manage numbers (Ruminant activity manage)\n\n## Properties\n\n- Perform growing out of young males as per last example\n- minimum breeder herd to 40 so purchases will be made from initial 20 till 40 individuals\n- maximum breeder herd to 60 where only herd replacement from breeding will increase herd from 40 to 60 breeders\n- maximum purchase as proportion of minimum breeders = 0.25 (40*0.25 = 10 individuals)\n- old breeders wil be sold at 120 months\n\n## Initial herd\n- 20 female breeders and 2 male breeders\n\n## Results\n- See BreederPurchase, BreederSales as category in HerdLedger report\n- The Herdsummary shows number in each class each month (plotted for breeders in Breeders graph)\n\n### Number of breeders graph\n- The purchase of breeders happens in the first two years in the manage herd activity.\n- New breeders enter the herd from births via prebreeders \n- Purchases are limited to 10 individuals per year\n- Recruitment from the herd allows the number of breeders to increase to the maximum 60\n- The breeder herd is maintained through recriutment vs deaths and the sale of old breeders and excess breeders from 1975 onwards\n- As the population of breeders does not all below 40 there are not further purchases",
          "Name": "Description",
          "ResourceName": null,
          "Children": [],
          "Enabled": true,
          "ReadOnly": false
        },
        {
          "$type": "Models.Clock, Models",
          "Start": "1970-01-01T00:00:00",
          "End": "1980-01-31T00:00:00",
          "Name": "clock",
          "ResourceName": null,
          "Children": [
            {
              "$type": "Models.CLEM.CLEMEvents, Models",
              "TimeStep": 30,
              "CustomTimeStep": 0,
              "EcologicalIndicatorsCalculationInterval": 12,
              "EcologicalIndicatorsCalculationMonth": 7,
              "Notes": null,
              "SelectedTab": null,
              "Name": "CLEMEvents",
              "ResourceName": null,
              "Children": [],
              "Enabled": true,
              "ReadOnly": false
            }
          ],
          "Enabled": true,
          "ReadOnly": false
        },
        {
