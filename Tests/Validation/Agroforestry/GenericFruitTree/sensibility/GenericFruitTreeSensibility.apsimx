      "Children": [
        {
          "$type": "Models.Memo, Models",
          "Name": "Group notes",
          "Text": "Reproductive-potential scenarios: bud load at sowing is varied while the orchard scaffold is otherwise unchanged. Higher bud load should increase flowering diagnostics and potential fruit set.",
          "Children": [],
          "Enabled": true,
          "ReadOnly": false
        }
      ],
      "Enabled": true,
