                        {
                          "Key": "returndays",
                          "Value": "3"
                        },
                        {
                          "Key": "maximumAmount",
                          "Value": "30"
                        },
                        {
                          "Key": "depthPAWC",
                          "Value": "650"
                        }
                      ],
