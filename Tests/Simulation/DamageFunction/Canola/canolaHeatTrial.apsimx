                    "namespace Models",
                    "{",
                    "    [Serializable] ",
                    "    public class Script : Model",
                    "    {",
                    "        [Description(\"Crop\")]",
                    "        public IPlant Crop { get; set; }",
                    "        ",
                    "        [EventSubscribe(\"DoManagement\")]",
                    "        private void OnDoManagement(object sender, EventArgs e)",
                    "        {",
                    "            if (Crop.IsReadyForHarvesting)",
                    "            {",
                    "                Crop.Harvest();",
                    "                Crop.EndCrop();",
                    "            }",
                    "        }",
                    "    }",
                    "}",
