                            "Divide([Maize].Grain.Number,[Maize].Cob.CobNumber) as GrainsPerCob",
                            "[Maize].Cob.Wt + [Maize].Grain.Wt as EarWt",
                            "[Maize].Cob.CobSize",
                            "[Maize].Grain.Number",
                            "[Maize].Root.Depth",
                            "[Maize].Root.Live.Wt",
                            "[Maize].Root.Wt"
