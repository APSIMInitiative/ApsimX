                  "Children": [
                    {
                      "$type": "Models.Memo, Models",
                      "Text": "Number of leaves the plant will produce when fully vernalised early and grown in long photoperiod\r\n",
                      "Name": "Memo",
                      "Children": [],
                      "IncludeInDocumentation": false,
                      "Enabled": true,
                      "ReadOnly": false
                    }
                  ],
