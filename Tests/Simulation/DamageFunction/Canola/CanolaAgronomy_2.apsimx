                      "Children": [
                        {
                          "$type": "Models.Manager, Models",
                          "CodeArray": [
                            "using Models.Soils.Nutrients;",
                            "using APSIM.Shared.Utilities;",
                            "using Models.Surface;",
                            "using Models.Utilities;",
                            "using Models.Soils;",
                            "using Models.PMF;",
                            "using Models.Core;",
                            "using System;",
                            "using Models.Interfaces;",
                            "",
                            "namespace Models",
                            "{",
                            "    [Serializable]",
                            "    public class Script : Model",
                            "    {",
                            "        [Link] private Clock Clock;",
                            "        [Link] private Plant Wheat;",
                            "        [Link] private ISoilWater SoilWater;",
                            "        [Link] private INutrient nutrient;",
                            "        [Link] private SurfaceOrganicMatter SOM;",
                            "        [Link] private Summary Summary;",
                            "",
                            "        [Description(\"Date to reset on:\")]",
                            "        public string ResetDate {get;set;}",
                            "",
                            "        [Description(\"Reset Water?\")]",
                            "        public string ResetWater {get;set;}",
                            "",
                            "        [Description(\"Reset Nitrogen?\")]",
                            "        public string ResetN {get;set;}",
                            "",
                            "        [Description(\"Reset Surface Organic Matter?\")]",
                            "        public string ResetSOM {get;set;}",
                            "",
                            "        [EventSubscribe(\"DoManagement\")]",
                            "        private void OnDoManagement(object sender, EventArgs e)",
                            "        {",
                            "            if (DateUtilities.WithinDates(ResetDate, Clock.Today, ResetDate))",
                            "            {",
                            "                if (ResetWater == \"Yes\")",
                            "                {",
                            "                    Summary.WriteMessage(this, \"Reset Water\", MessageType.Diagnostic);",
                            "                    SoilWater.Reset();",
                            "                }",
                            "                if (ResetN == \"Yes\")",
                            "                {",
                            "                    Summary.WriteMessage(this, \"Reset Nitrogen\", MessageType.Diagnostic);",
                            "                    nutrient.Reset();",
                            "                }",
                            "                if (ResetSOM == \"Yes\")",
                            "                {",
                            "                    Summary.WriteMessage(this, \"Reset Surface OM\", MessageType.Diagnostic);",
                            "                    SOM.Reset();",
                            "                }",
                            "            }",
                            "        }",
                            "    }",
                            "}"
                          ],
                          "Parameters": [
                            {
                              "Key": "ResetDate",
                              "Value": "28-Mar"
                            },
                            {
                              "Key": "ResetWater",
                              "Value": "Yes"
                            },
                            {
                              "Key": "ResetN",
                              "Value": "No"
                            },
                            {
                              "Key": "ResetSOM",
                              "Value": "No"
                            }
                          ],
                          "Name": "Reset on date",
                          "ResourceName": null,
                          "Children": [],
                          "Enabled": true,
                          "ReadOnly": false
                        },
                        {
                          "$type": "Models.Manager, Models",
                          "CodeArray": [
                            "using APSIM.Shared.Utilities;",
                            "using Models.Utilities;",
                            "using Models.Soils;",
                            "using Models.PMF;",
                            "using Models.Core;",
                            "using System;",
                            "",
                            "namespace Models",
                            "{",
                            "    [Serializable]",
                            "    public class Script : Model",
                            "    {",
                            "        [Link] Clock Clock;",
                            "        [Link] Fertiliser Fertiliser;",
                            "        [Link] Summary Summary;",
                            "        [Link] Plant Canola;",
                            "        [Link] Soil Soil;",
                            "        Accumulator accumulatedRain;",
                            "        ",
                            "        [Description(\"Sowing date (d-mmm)\")]",
                            "        public string SowDate { get; set; }",
                            "        [Description(\"Cultivar to be sown\")]",
                            "        public string CultivarName { get; set; }",
                            "        [Description(\"Sowing depth (mm)\")]",
                            "        public double SowingDepth { get; set; }",
                            "        [Description(\"Row spacing (mm)\")]",
                            "        public double RowSpacing { get; set; }",
                            "        [Description(\"Plant population (/m2)\")]",
                            "        public double Population { get; set; }",
                            "        ",
                            "        ",
                            "",
                            "",
                            "        [EventSubscribe(\"DoManagement\")]",
                            "        private void OnDoManagement(object sender, EventArgs e)",
                            "        {",
                            "        ",
                            "            ",
                            "            if (DateUtilities.WithinDates(SowDate, Clock.Today, SowDate))",
                            "            {",
                            "                Canola.Sow(population: Population, cultivar: CultivarName, depth: SowingDepth, rowSpacing: RowSpacing);    ",
                            "            }",
                            "        ",
                            "        }",
                            "        ",
                            "    }",
                            "}"
                          ],
                          "Parameters": [
                            {
                              "Key": "SowDate",
                              "Value": "25-Apr"
                            },
                            {
                              "Key": "CultivarName",
                              "Value": "Hyola575"
                            },
                            {
                              "Key": "SowingDepth",
                              "Value": "20"
                            },
                            {
                              "Key": "RowSpacing",
                              "Value": "250"
                            },
                            {
                              "Key": "Population",
                              "Value": "45"
                            }
                          ],
                          "Name": "Sowing",
                          "ResourceName": null,
                          "Children": [],
                          "Enabled": true,
                          "ReadOnly": false
                        },
                        {
                          "$type": "Models.Manager, Models",
                          "CodeArray": [
                            "using Models.Soils.Nutrients;",
                            "using System;",
                            "using Models.Soils;",
                            "using Models.Core;",
                            "using Models.PMF;",
                            "using APSIM.Shared.Utilities;",
                            "namespace Models",
                            "{",
                            "    [Serializable]",
                            "    public class Script : Model",
                            "    {",
                            "        [Link] Clock Clock;",
                            "        [Link] Fertiliser Fertiliser;",
                            "        [Link] INutrient nutrient;",
                            "        [Link] Summary sum;",
                            "        ",
                            "        [Separator(\"A component to apply fertiliser on one or more dates on every year of the simulation\")]",
                            "",
                            "        [Description(\"Type of fertiliser to apply? \")] ",
                            "        [Display(Type = DisplayType.FertiliserType)]public string FertiliserType { get; set; }",
                            "",
                            "        [Description(\"Enter the fertilisation dates as dd-mmm with comma separation (any year information entered will be ignored): \")] ",
                            "        public string[] FertiliserDates { get; set; } ",
                            "",
                            "        [Description(\"Don't add fertiliser if N in top 2 layers exceeds (kg/ha) : \")]",
                            "        public double fert_criteria { get; set; }",
                            "",
                            "        [Description(\"Amount of fertiliser to be applied each time (kg /ha)\")] ",
                            "        public double Amount { get; set; }",
                            "",
                            "        [Description(\"Depth (mm)\")] public double FertiliserDepth { get; set; }",
                            "        ",
                            "        [EventSubscribe(\"DoManagement\")]",
                            "        private void OnDoManagement(object sender, EventArgs e)",
                            "        {",
                            "            foreach (string ddMMM in FertiliserDates)",
                            "            {",
                            "                if (DateUtilities.DatesEqual(ddMMM, Clock.Today))",
                            "                {",
                            "                    double soil_N = nutrient.NH4.kgha[0] + nutrient.NO3.kgha[0] + nutrient.NH4.kgha[1] + nutrient.NO3.kgha[1];",
                            "                    if (soil_N <= fert_criteria) ",
                            "                         Fertiliser.Apply(amount: Amount, type: FertiliserType, depth: FertiliserDepth);",
                            "                    else",
                            "                        sum.WriteMessage(this, \"No fertilising as top two layers have \" + soil_N.ToString() + \"kg/ha N\", MessageType.Diagnostic);",
                            "                }",
                            "            }",
                            "        }",
                            "    }",
                            "}"
                          ],
                          "Parameters": [
                            {
                              "Key": "FertiliserType",
                              "Value": "UreaN"
                            },
                            {
                              "Key": "FertiliserDates",
                              "Value": "6-Dec"
                            },
                            {
                              "Key": "fert_criteria",
                              "Value": "1000"
                            },
                            {
                              "Key": "Amount",
                              "Value": "0"
                            },
                            {
                              "Key": "FertiliserDepth",
                              "Value": "0"
                            }
                          ],
                          "Name": "Fertilise",
                          "ResourceName": null,
                          "Children": [],
                          "Enabled": true,
                          "ReadOnly": false
                        },
