                            "[Maize].Grain.Wt",
                            "",
                            "[Maize].Phenology.EmergenceDAS",
                            "[Maize].Phenology.FloweringDAS",
                            "[Maize].Phenology.MaturityDAS",
                            "[Maize].DaysAfterSowing",
                            "[Maize].Population",
                            "",
                            "[Maize].AboveGround.Wt",
                            "[Maize].AboveGround.N",
                            "",
                            "[Maize].Leaf.Wt",
                            "[Maize].Stem.Wt",
                            "[Maize].Cob.Wt",
                            "",
                            "[Maize].Cob.Wt + [Maize].Grain.Wt as GrainandCob",
                            "[Maize].Husk.Wt as OtherWt",
                            "",
                            "[Maize].Leaf.AppearedCohortNo",
                            "[Maize].Structure.LeafTipsAppeared",
                            "[Maize].Leaf.ExpandedCohortNo",
                            "[Maize].Leaf.LAI",
                            "[ExtraVariables].Script.LeafExpandedPosition",
                            "[ExtraVariables].Script.MostRecentlyExpandedLeafSize",
                            "",
