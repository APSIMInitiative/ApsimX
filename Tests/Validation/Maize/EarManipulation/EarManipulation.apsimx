                        {
                          "$type": "Models.Manager, Models",
                          "CodeArray": [
                            "using Newtonsoft.Json;",
                            "using Models.Soils.Nutrients;",
                            "using System;",
                            "using Models.Core;",
                            "using System.Collections.Generic;",
                            "using System.Text;",
                            "using Models.Soils;",
                            "using Models.PMF;",
                            "using Models;",
                            "using System.Xml.Serialization;",
                            "using APSIM.Shared.Utilities;",
                            "using Models.PMF.Phen;",
                            "",
                            "namespace Models",
                            "{",
                            "    [Serializable] ",
                            "    public class Script : Model",
                            "    {",
                            "        [Link] private Plant Maize;",
                            "        [Link] private Zone zone;",
                            "        [Link] private Simulation sim;",
                            "        [Link(Type = LinkType.Path, Path = \"[Maize].Phenology\")]",
                            "        private Phenology phenology;",
                            "",
                            "",
                            "        [JsonIgnore] private bool Harvested {get; set;}",
                            "                ",
                            "        [EventSubscribe(\"StartOfSimulation\")]",
                            "        private void OnSimulationCommencing(object sender, EventArgs e)",
                            "        {",
                            "        ",
                            "        Harvested = false;",
                            "        }",
                            "        ",
                            "        [EventSubscribe(\"DoManagement\")]",
                            "        private void OnDoManagement(object sender, EventArgs e)",
                            "        {",
                            "            if ((phenology.CurrentPhase.Name == \"ReadyForHarvesting\") & (Harvested == false))",
                            "            {",
                            "                Maize.Harvest(removeBiomassFromOrgans: false);",
                            "                //Maize.EndCrop();",
                            "                Harvested = true;",
                            "            }",
                            "        }",
                            "        ",
                            "        [EventSubscribe(\"DoManagementCalculations\")]",
                            "        private void OnDoManagementCalculations(object sender, EventArgs e)",
                            "        {",
                            "            ",
                            "        }",
                            "    }",
                            "}",
                            "       "
                          ],
                          "Parameters": [],
                          "Name": "Harvesting",
                          "ResourceName": null,
                          "Children": [],
