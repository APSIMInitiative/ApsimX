        {
          "$type": "Models.Manager, Models",
          "CodeArray": [
            "using Models.PMF.Phen;",
            "using System;",
            "using Models.Core;",
            "using System.Collections.Generic;",
            "using System.Text;",
            "using Models.Soils;",
            "using Models.PMF;",
            "using Models;",
            "using System.Xml.Serialization;",
            "using APSIM.Shared.Utilities;",
            "",
            "namespace Models",
            "{",
            "    [Serializable] ",
            "    public class Script : Model",
            "    {",
            "        [Link] private Plant Canola;",
            "        [Link] private Clock Clock;",
            "        [Link(Type = LinkType.Path, Path = \"[Canola].Phenology\")]",
            "        private Phenology phenology;",
            "",
            "        [EventSubscribe(\"DoManagement\")]",
            "        private void OnDoManagement(object sender, EventArgs e)",
            "        {",
            "            if ((phenology.CurrentPhase.Name == \"ReadyForHarvesting\")||(Canola.IsAlive&&DateUtilities.DatesEqual(\"31-Dec\", Clock.Today)))",
            "            {",
            "                Canola.Harvest();",
            "                Canola.EndCrop();",
            "            }",
            "        }",
            "    }",
            "}",
            "       "
          ],
          "Parameters": [],
          "Name": "Harvesting",
          "ResourceName": null,
          "Children": [],
          "Enabled": true,
          "ReadOnly": false
        },
        {
          "$type": "Models.Report, Models",
          "VariableNames": [
            "[Clock].Today",
            "[Canola].SowingData.Cultivar",
            "[IWeather].Latitude",
