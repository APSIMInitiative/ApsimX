                        "[Canola].Phenology.MaturityDAS",
                        "[Canola].AboveGround.Wt",
                        "[FrostHeatDamageFunctions].FrostHeatYield as Canola.Grain.Wt"
                      ],
                      "EventNames": [
                        "[Canola].Harvesting"
                      ],
                      "GroupByVariableName": null,
                      "Name": "DamageFunctionHarvestReport",
                      "ResourceName": null,
                      "Children": [],
                      "Enabled": true,
                      "ReadOnly": false
                    }
                  ],
