                        {
                          "$type": "Models.Manager, Models",
                          "CodeArray": [
                            "using APSIM.Shared.Utilities;",
                            "using Models.Utilities;",
                            "using Models.Soils;",
                            "using Models.PMF;",
                            "using Models.Core;",
                            "using System;",
                            "",
                            "namespace Models",
                            "{",
                            "    [Serializable]",
                            "    public class Script : Model",
                            "    {",
                            "        [Link] Clock Clock;",
                            "        [Link] Fertiliser Fertiliser;",
                            "        [Link] Summary Summary;",
                            "        [Link] Soil Soil;",
                            "        ",
                            "        [Description(\"Crop\")]",
                            "        public IPlant Crop { get; set; }",
                            "",
                            "        [Description(\"Sowing date (d-mmm)\")]",
                            "        public string SowDate { get; set; }",
                            "",
                            "        [Display(Type = DisplayType.CultivarName)]",
                            "        [Description(\"Cultivar to be sown\")]",
                            "        public string CultivarName { get; set; }",
                            "",
                            "        [Description(\"Sowing depth (mm)\")]",
                            "        public double SowingDepth { get; set; }",
                            "",
                            "        [Description(\"Row spacing (mm)\")]",
                            "        public double RowSpacing { get; set; }",
                            "",
                            "        [Description(\"Plant population (/m2)\")]",
                            "        public double Population { get; set; }",
                            "",
                            "        [EventSubscribe(\"DoManagement\")]",
                            "        private void OnDoManagement(object sender, EventArgs e)",
                            "        {",
                            "            if (DateUtilities.WithinDates(SowDate, Clock.Today, SowDate))",
                            "            {",
                            "                Crop.Sow(population: Population, cultivar: CultivarName, depth: SowingDepth, rowSpacing: RowSpacing);    ",
                            "            }",
                            "        }",
                            "    }",
                            "}"
                          ],
                          "Parameters": [
                            {
                              "Key": "Crop",
                              "Value": "[Maize]"
                            },
                            {
                              "Key": "SowDate",
                              "Value": "13-May"
                            },
                            {
                              "Key": "CultivarName",
                              "Value": "DKC63"
                            },
                            {
                              "Key": "SowingDepth",
                              "Value": "70"
                            },
                            {
                              "Key": "RowSpacing",
                              "Value": "760"
                            },
                            {
                              "Key": "Population",
                              "Value": "8.6"
                            }
                          ],
                          "Name": "Sow on a fixed date",
                          "ResourceName": null,
                          "Children": [],
                          "Enabled": true,
                          "ReadOnly": false
                        },
                        {
                          "$type": "Models.Manager, Models",
                          "CodeArray": [
                            "using APSIM.Shared.Utilities;",
                            "using Models.Utilities;",
                            "using Models.Soils;",
                            "using Models.PMF;",
                            "using Models.Core;",
                            "using System;",
                            "using System.Linq;",
                            "",
                            "namespace Models",
                            "{",
                            "    [Serializable] ",
                            "    public class Script : Model",
                            "    {",
                            "        [Description(\"Crop\")]",
                            "        public IPlant Crop { get; set; }",
                            "        ",
                            "        [EventSubscribe(\"DoManagement\")]",
                            "        private void OnDoManagement(object sender, EventArgs e)",
                            "        {",
                            "            if (Crop.IsReadyForHarvesting)",
                            "            {",
                            "                Crop.Harvest();",
                            "                Crop.EndCrop();",
                            "            }",
                            "        }",
                            "    }",
                            "}",
                            "       "
                          ],
                          "Parameters": [
                            {
                              "Key": "Crop",
                              "Value": "[Maize]"
                            }
                          ],
                          "Name": "Harvesting",
                          "ResourceName": null,
                          "Children": [],
                          "Enabled": true,
                          "ReadOnly": false
                        },
                        {
                          "$type": "Models.Manager, Models",
                          "CodeArray": [
                            "using APSIM.Core;",
                            "using APSIM.Shared.Utilities;",
                            "using Models.PMF.Interfaces;",
                            "using Models.PMF;",
                            "using Models.Interfaces;",
                            "using Models.Core;",
                            "using System;",
                            "",
                            "namespace Models;",
                            "",
                            "[Serializable]",
                            "public class Script : Model, IStructureDependency",
                            "{",
                            "        [Link] private IClock Clock;",
                            "        [Link] private ISummary Summary;",
                            "        private IHasDamageableBiomass theOrgan;",
                            "        ",
                            "        public IStructure Structure { private get; set; }",
                            "    ",
                            "    [Description(\"What crop.\")]",
                            "    public IPlant TargetPlant { get; set; }",
                            "    ",
                            "    [Description(\"Remove what Organ?\")]",
                            "    public string Organ { get; set; }",
                            "    ",
                            "    [Description(\"Removal amount.\")]",
                            "    public double ToRemove { get; set; }",
                            "    ",
                            "    [Description(\"Date to remove on (dd-mmm).\")]",
                            "    public string Date { get; set; }",
                            "    ",
                            "    [EventSubscribe(\"StartOfSimulation\")]",
                            "    private void OnStartOfSimulation(object sender, EventArgs e)",
                            "    {",
                            "            theOrgan =   Structure.FindChild<IHasDamageableBiomass>(Organ, relativeTo: (INodeModel)TargetPlant);",
                            "            if (theOrgan is null)",
                            "                throw new Exception(\"Could not link organ!\");",
                            "    }",
                            "    ",
                            "    [EventSubscribe(\"DoManagement\")]",
                            "    private void DoDailyCalculations(object sender, EventArgs e)",
                            "    {",
                            "        if (DateUtilities.DatesAreEqual(Date, Clock.Today))",
                            "        {",
                            "            theOrgan.RemoveBiomass(liveToRemove: 0.0, ",
                            "                                   deadToRemove: 0.0, ",
                            "                                   liveToResidue: ToRemove, ",
                            "                                   deadToResidue: ToRemove);",
                            "        }",
                            "    }",
                            "}",
                            ""
                          ],
                          "Parameters": [
                            {
                              "Key": "TargetPlant",
                              "Value": "[Maize]"
                            },
                            {
                              "Key": "Organ",
                              "Value": "Leaf"
                            },
                            {
                              "Key": "ToRemove",
                              "Value": "1"
                            },
                            {
                              "Key": "Date",
                              "Value": "26-jul"
                            }
                          ],
                          "Name": "RemoveStuff",
                          "ResourceName": null,
                          "Children": [],
                          "Enabled": true,
                          "ReadOnly": false
                        },
