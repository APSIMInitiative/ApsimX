                },
                {
                  "$type": "Models.Manager, Models",
                  "CodeArray": [
                    "/*-------------------------------------------------------------------------------------",
                    "Sheep grazing wheat when conditions are suitable, and in feedlot the rest of the time.",
                    "---------------------------------------------------------------------------------------",
                    "",
                    "In this script animals are bought and sold within a specified date window.",
                    "They are fed supplement in a feedlot at a set rate, but graze a wheat crop when a criteria is met.",
                    "Animals are moved from the wheat crop and back to feedlot when a second criteria is met.",
                    "",
                    "Based on Sprague SJ, Kirkegaard JA, Dove H, Graham JM, McDonald SE, Kelman WM (2015) Integrating dual-purpose wheat and canola into high-rainfall livestock systems in south-eastern Australia. 1. Crop forage and grain yield. Crop and Pasture Science 66(4), 365-376. ",
                    "",
                    "Activities in this manager:",
                    "1. Buy animals at start of year & put in feedlot",
                    "2. Move animals from feedlot to crop when ready to graze",
                    "3. Move animals from crop to feedlot ",
                    "4. Shear all animals on specified date",
                    "5. Sell all animals at end of year",
                    "",
                    "NOTES",
                    "1. When the animals are in the feedlot and an animal dies during the day, the supplement has already been fed into the feedlot",
                    "   based on the number of animals in the feedlot at the start of the day. This means the remaining animals have access to slightly",
                    "   more supplement and causes a spike in supp intake graph",
                    "2. When sheep are culled for age + purchased to maintain stocking rate, several groups of sheep are created.",
                    "   This causes irregular amounts of supplement to be fed.",
                    "--------------------------------------------------------------------------------------*/",
                    "",
                    "",
                    "using System.Linq;",
                    "using System;",
                    "using System.Collections.Generic;",
                    "using Models.Core;",
                    "using Models.PMF;",
                    "using Models.Functions;",
                    "using Models.Soils;",
                    "using Models.Utilities;",
                    "using Models.GrazPlan;",
                    "using APSIM.Shared.Utilities;",
                    "using System.Diagnostics;",
                    "",
                    "namespace Models",
                    "{",
                    "    [Serializable]",
                    "    [Description(",
                    "        \"<p><b>Animals grazing a crop when conditions are suitable, and in feedlot the rest of the time.</b></p>\" +",
                    "        \"In this script animals are bought and sold within a specified date window. \" +",
                    "        \"They are fed supplement in a feedlot at a set rate, but graze a wheat crop when a criteria is met. \" +",
                    "        \"Animals are moved from the wheat crop and back to feedlot when a second criteria is met.\")]    ",
                    "    public class Script : Model",
                    "    {",
                    "        [Link] Clock clock;",
                    "        [Link] Stock Animals;",
                    "        [Link] Supplement Feed;",
                    "        [Link] Summary Summary;",
                    "        [Link] IPlant plant;",
                    "        [Link] Soil Soil;",
                    "        [Link] Zone Paddock;",
                    "",
                    "        private IBooleanFunction expressionMoveAnimalsToField;",
                    "        private IBooleanFunction expressionMoveAnimalsToFeedlot;",
                    "",
                    "        public enum SellPolicyType",
                    "        {",
                    "            Date,",
                    "            PercentageHerdWhenAverageWeightGreaterThan,",
                    "            PercentageHerdWhenAverageAgeGreaterThan,",
                    "            CulledForAge,",
                    "            CulledForWeight,",
                    "            SellYoung",
                    "        }",
                    "",
                    "        ////////////////////////////////////////////////////////",
                    "        [Separator(\"Buying of animals\")]",
                    "",
                    "        [Description(\"Buy animals?\")] ",
                    "        public bool Buying { get; set; }",
                    "",
                    "        [Description(\"Stock: genotype (e.g. Small Merino, Angus, Friesian):\")] ",
                    "        [Display(Values = \"GetGenotypes\")]",
                    "        public string Genotype { get; set; }",
                    "",
                    "        [Description(\"Stock: sex (Female, Male, Castrate):\")] ",
                    "        public ReproductiveType Sex { get; set; }",
                    "",
                    "        [Description(\"Date to buy animals (dd-mmm)\")] ",
                    "        [Display(EnabledCallback = \"BuyingEnabled\")]",
                    "        public string BuyDate { get; set; }",
                    "",
                    "        [Description(\"Age of bought animals (months): \")] ",
                    "        [Display(EnabledCallback = \"BuyingEnabled\")]",
                    "        public double BuyAge { get; set; }",
                    "",
                    "        [Description(\"Weight of bought animals (kg): \")] ",
                    "        [Display(EnabledCallback = \"BuyingEnabled\")]",
                    "        public double BuyWeight { get; set; }",
                    "",
                    "        [Description(\"Zero denotes not lactating; 1 or more denotes the time (days) since parturition:\")] ",
                    "        [Display(EnabledCallback = \"BuyingEnabled\")]",
                    "        public int BuyLactating { get; set; }",
                    "",
                    "        [Description(\"Number of animals to buy: \")] ",
                    "        [Display(EnabledCallback = \"BuyingEnabled\")]",
                    "        public int NumAntoBuy { get; set; }",
                    "",
                    "        ////////////////////////////////////////////////////////",
                    "        [Separator(\"Selling of animals\")]",
                    "",
                    "        [Description(\"Selling animals?\")] ",
                    "        public bool Selling { get; set; }",
                    "",
                    "        [Description(\"First date to consider selling animals (dd-mmm)\")] ",
                    "        public string SaleFirstDate { get; set; }",
                    "",
                    "        [Description(\"Last date to consider selling animals (dd-mmm)\")] ",
                    "        public string SaleLastDate { get; set; }",
                    "",
                    "        [Description(\"Selling policy \")] ",
                    "        [Display(EnabledCallback = \"SellingEnabled\")]",
                    "        public SellPolicyType SellPolicy { get; set; }",
                    "",
                    "        [Description(\"Age at which to sell (months): \")] ",
                    "        [Display(EnabledCallback = \"SellingAgeEnabled\")]",
                    "        public int SaleAge { get; set; }",
                    "",
                    "        [Description(\"Weight at which to sell (kg): \")] ",
                    "        [Display(EnabledCallback = \"SellingWeightEnabled\")]",
                    "        public double SaleWeight { get; set; }",
                    "",
                    "        [Description(\"Percentage of animals to sell (%)\")] ",
                    "        [Display(EnabledCallback = \"SellingEnabled\")]",
                    "        public double SalePercentAnimals { get; set; }",
                    "",
                    "        ////////////////////////////////////////////////////////",
                    "        [Separator(\"Rule for moving animals into and out of paddock\")]",
                    "",
                    "        [Description(\"Name of paddock to move animals in to:\")] ",
                    "        [Display(Type = DisplayType.Model, ModelType = typeof(Zone))]",
                    "        public IModel PaddockToMoveAnimalsTo { get; set; }",
                    "",
                    "        [Description(\"First date to consider moving animals:\")] ",
                    "        public string GrazingWindowStartDate { get; set; }",
                    "",
                    "        [Description(\"Last date to consider moving animals:\")] ",
                    "        public string GrazingWindowEndDate { get; set; }",
                    "",
                    "        [Description(\"Criteria to move animals to field\")]",
                    "        public string ExpressionToMoveAnimalsToField { get; set; }",
                    "",
                    "        [Description(\"Criteria to move animals to feedlot\")]",
                    "        public string ExpressionToMoveAnimalsToFeedlot { get; set; }",
                    "",
                    "",
                    "        ////////////////////////////////////////////////////////",
                    "        [Separator(\"Shearing\")]",
                    "        [Description(\"Date to shear animals (dd-mmm)\")] ",
                    "        public string ShearDate { get; set; }",
                    "",
                    "        [Description(\" \")] ",
                    "        public string Dummy { get; set; }",
                    "",
                    "        ////////////////////////////////////////////////////////////////////////////",
                    "        // Callback properties to control disabling of properties.",
                    "        ////////////////////////////////////////////////////////////////////////////",
                    "        public bool BuyingEnabled { get { return Buying; } }",
                    "",
                    "        public bool SellingEnabled { get { return Selling; } }",
                    "",
                    "        public bool SellingAgeEnabled",
                    "        { ",
                    "            get",
                    "            { ",
                    "                return Selling &&",
                    "                (SellPolicy == SellPolicyType.PercentageHerdWhenAverageAgeGreaterThan || SellPolicy == SellPolicyType.CulledForAge);",
                    "            } ",
                    "        }",
                    "",
                    "        public bool SellingWeightEnabled",
                    "        { ",
                    "            get",
                    "            { ",
                    "                return Selling &&",
                    "                (SellPolicy == SellPolicyType.PercentageHerdWhenAverageWeightGreaterThan || SellPolicy == SellPolicyType.CulledForWeight);",
                    "            } ",
                    "        }",
                    "",
                    "        ////////////////////////////////////////////////////////////////////////////",
                    "        // Outputs",
                    "        ////////////////////////////////////////////////////////////////////////////",
                    "        // <summary>Number of animals sold.</summary>",
                    "        public int NumberSold { get; set; }",
                    "",
                    "        // <summary>Description of something that has happened.</summary>",
                    "        public string EventName { get; set; }",
                    "",
                    "        // <summary>Return a list of genotypes to the properties tab.</summary>",
                    "        public string[] GetGenotypes()",
                    "        {",
                    "            if (Animals != null)",
                    "                return Animals.Genotypes.Names.ToArray();",
                    "            return null;",
                    "        }",
                    "",
                    "        public string CurrentLocation { get; set; }  // location of the sheep",
                    "",
                    "",
                    "",
                    "        // ============================================================",
                    "        // Called once at beginning of simulation run",
                    "        // ============================================================",
                    "        [EventSubscribe(\"StartOfSimulation\")]",
                    "        private void OnStartOfSimulation(object sender, EventArgs e)",
                    "        {",
                    "            if (string.IsNullOrEmpty(ExpressionToMoveAnimalsToField))",
                    "                throw new Exception(\"You must specify a criteria for moving animals to the field\");",
                    "                ",
                    "            if (CSharpExpressionFunction.Compile(ExpressionToMoveAnimalsToField, Node, out IBooleanFunction function, out string errorMessages))",
                    "                expressionMoveAnimalsToField = function;",
                    "            else",
                    "                throw new Exception(errorMessages);",
                    "                        ",
                    "            if (string.IsNullOrEmpty(ExpressionToMoveAnimalsToFeedlot))",
                    "                throw new Exception(\"You must specify a criteria for moving animals to the feedlot\");",
                    "            if (CSharpExpressionFunction.Compile(ExpressionToMoveAnimalsToFeedlot, Node, out IBooleanFunction function2, out string errorMessages2))",
                    "                expressionMoveAnimalsToFeedlot = function2;",
                    "            else",
                    "                throw new Exception(errorMessages2);",
                    "",
                    "            CurrentLocation = \"\";",
                    "        }",
                    "",
                    "",
                    "",
                    "        // ============================================================",
                    "        // Management that happens every day.",
                    "        // ============================================================",
                    "        [EventSubscribe(\"DoManagement\")]",
                    "        private void OnDoManagement(object sender, EventArgs e)",
                    "        {",
                    "            EventName = string.Empty;",
                    "",
                    "            // Buy animals",
                    "            if (Buying && DateUtilities.DatesAreEqual(BuyDate, clock.Today))",
                    "            {",
                    "                var purchase = new StockBuy();",
                    "                purchase.Genotype = Genotype;   // \"small merino\"",
                    "                purchase.Number = NumAntoBuy;",
                    "                purchase.Sex = Sex;               // \"wethers\"",
                    "                purchase.Age = BuyAge;",
                    "                purchase.Weight = BuyWeight;",
                    "                purchase.Lactating = BuyLactating;",
                    "                Animals.Buy(purchase);",
                    "                Animals.Move(\"Feedlot\");",
                    "                EventName = NumAntoBuy + \" animals bought\";",
                    "",
                    "                CurrentLocation = \"Feedlot\";",
                    "            }",
                    "",
                    "            // Sell animals",
                    "            if (SellingEnabled && DateUtilities.WithinDates(SaleFirstDate, clock.Today, SaleLastDate))",
                    "            { ",
                    "                if (SellPolicy == SellPolicyType.PercentageHerdWhenAverageWeightGreaterThan || ",
                    "                    SellPolicy == SellPolicyType.PercentageHerdWhenAverageAgeGreaterThan)",
                    "                {",
                    "                    bool doSell = false;",
                    "                    if (SellPolicy == SellPolicyType.Date)",
                    "                        doSell = true;",
                    "                    else if (SellPolicy == SellPolicyType.PercentageHerdWhenAverageWeightGreaterThan && Animals.WeightAll >= SaleWeight)",
                    "                        doSell = true;",
                    "                    else if (SellPolicy == SellPolicyType.PercentageHerdWhenAverageAgeGreaterThan && Animals.AgeMonthsAll >= SaleAge)",
                    "                        doSell = true;",
                    "",
                    "                    if (doSell)",
                    "                    {",
                    "                        NumberSold = Convert.ToInt32(Animals.NumberAll * SalePercentAnimals / 100.0);",
                    "                        Animals.Sell(NumberSold);",
                    "                        EventName = NumberSold + \" animals sold\";",
                    "                    }",
                    "                }",
                    "                else",
                    "                {",
                    "                    IEnumerable<AnimalGroup> animalsToSell = null;",
                    "                    if (SellPolicy == SellPolicyType.CulledForAge)",
                    "                    {",
                    "                        // split older animals into a new group",
                    "                        animalsToSell = Animals.SplitByAge(Convert.ToInt32(SaleAge * 30)); // months to days",
                    "                    }",
                    "                    else if (SellPolicy == SellPolicyType.CulledForWeight)",
                    "                    {",
                    "                        // split heavier animals into a new group",
                    "                        animalsToSell = Animals.SplitByWeight(SaleWeight);",
                    "                    }",
                    "                    else if (SellPolicy == SellPolicyType.SellYoung)",
                    "                    {",
                    "                        // split young (offspring) into new groups",
                    "                        animalsToSell = Animals.SplitByYoung();",
                    "                    }",
                    "                    if (animalsToSell != null)",
                    "                    {",
                    "                        var numberSellableAnimals = animalsToSell.Sum(g => g.NoAnimals);",
                    "                        var numberAnimalsToSell = Convert.ToInt32(numberSellableAnimals * SalePercentAnimals / 100.0);",
                    "                        if (numberAnimalsToSell > 0)",
                    "                            Animals.Sell(numberAnimalsToSell, animalsToSell);",
                    "                    }",
                    "                }",
                    "            }",
                    "",
                    "",
                    "            // Determine whether the animals are in the feedlot.",
                    "            bool animalsAreInFeedlot = Animals.AnimalGroups.FirstOrDefault(group => group.PaddOccupied.Name == \"Feedlot\") != null;",
                    "            bool inGrazingWindow = DateUtilities.WithinDates(GrazingWindowStartDate, clock.Today, GrazingWindowEndDate);",
                    "",
                    "            if (animalsAreInFeedlot)",
                    "            {",
                    "                   // Animals are in feedlot. Determine if they can be moved to paddock.",
                    "                if (inGrazingWindow && expressionMoveAnimalsToField.Value())",
                    "                {",
                    "                    Animals.Move(PaddockToMoveAnimalsTo.Name);",
                    "                    EventName = \"Animals moved to paddock\";",
                    "                    CurrentLocation = \"Paddock\";",
                    "                }",
                    "            }",
                    "            else",
                    "            {",
                    "                // Animals are in paddock. Determine if they need to be moved to feedlot.",
                    "                if (!inGrazingWindow || expressionMoveAnimalsToFeedlot.Value())",
                    "                {",
                    "                    Animals.Move(\"Feedlot\");",
                    "                    CurrentLocation = \"Feedlot\";",
                    "                    EventName = \"Animals moved to feedlot\";",
                    "                }",
                    "            }",
                    "",
                    "            // Shear all animals on specified date",
                    "            if (DateUtilities.DatesEqual(ShearDate, clock.Today))",
                    "            {",
                    "                Animals.Shear(shearAdults: true, shearYoung: true);",
                    "                EventName = \"Animals shorn\";",
                    "            }",
                    "        }",
                    "    }",
                    "}"
                  ],
                  "Parameters": [
                    {
                      "Key": "Buying",
                      "Value": "True"
                    },
                    {
                      "Key": "Genotype",
                      "Value": "Small Merino"
                    },
                    {
                      "Key": "Sex",
                      "Value": "Female"
                    },
                    {
                      "Key": "BuyDate",
                      "Value": "1-Jan"
                    },
                    {
                      "Key": "BuyAge",
                      "Value": "12"
                    },
                    {
                      "Key": "BuyWeight",
                      "Value": "30"
                    },
                    {
                      "Key": "BuyLactating",
                      "Value": "0"
                    },
                    {
                      "Key": "NumAntoBuy",
                      "Value": "50"
                    },
                    {
                      "Key": "Selling",
                      "Value": "True"
                    },
                    {
                      "Key": "SaleFirstDate",
                      "Value": "20-Dec"
                    },
                    {
                      "Key": "SaleLastDate",
                      "Value": "20-Dec"
                    },
                    {
                      "Key": "SellPolicy",
                      "Value": "CulledForAge"
                    },
                    {
                      "Key": "SaleAge",
                      "Value": "36"
                    },
                    {
                      "Key": "SaleWeight",
                      "Value": "NaN"
                    },
                    {
                      "Key": "SalePercentAnimals",
                      "Value": "100"
                    },
                    {
                      "Key": "PaddockToMoveAnimalsTo",
                      "Value": "[WheatSheep]"
                    },
                    {
                      "Key": "GrazingWindowStartDate",
                      "Value": "1-Jan"
                    },
                    {
                      "Key": "GrazingWindowEndDate",
                      "Value": "31-Dec"
                    },
                    {
                      "Key": "ExpressionToMoveAnimalsToField",
                      "Value": "Wheat.Phenology.Zadok > 0 && Wheat.Phenology.Zadok < 31 && Wheat.AboveGround.Wt >= 240"
                    },
                    {
                      "Key": "ExpressionToMoveAnimalsToFeedlot",
                      "Value": "Wheat.Phenology.Zadok >= 31 || Wheat.AboveGround.Wt <= 50"
                    },
                    {
                      "Key": "ShearDate",
                      "Value": "15-dec"
                    },
                    {
                      "Key": "Dummy",
                      "Value": ""
                    }
                  ],
                  "Name": "ManageStock",
                  "ResourceName": null,
                  "Children": [],
                  "Enabled": true,
                  "ReadOnly": false
                },
                {
                  "$type": "Models.Manager, Models",
                  "CodeArray": [
                    "using APSIM.Shared.Utilities;",
                    "using Models.GrazPlan;",
                    "using Models.Utilities;",
                    "using Models.Soils;",
                    "using Models.Soils.Nutrients;",
                    "using Models.PMF;",
                    "using Models.Core;",
                    "using System;",
                    "using System.Linq;",
                    "",
                    "namespace Models",
                    "{",
                    "    [Description(",
                    "    \"<b>Supplement store management.</b>\" +",
                    "    \"<li>When animals are in feedlot, they are fed a set amount each day.</li>\" +",
                    "    \"<li>Will restock the supplement store when the store reaches a minimum level.</li>\"",
                    "    )]",
                    "    [Serializable]",
                    "    public class ManageSupplement : Model",
                    "    {",
                    "        [Link] Clock clock;",
                    "        [Link] Stock animals;",
                    "        [Link] Supplement supplement;",
                    "",
                    "        [Description(\"Name of zone representing the feedlot\")]",
                    "        [Display(Type=DisplayType.Model, ModelType=typeof(Zone))]",
                    "        public IModel FeedlotZone { get; set; }",
                    "",
                    "        [Description(\"The amount of suppliment to feed each animal each day (kg)\")]",
                    "        public double SupplementAmount { get; set; }",
                    "",
                    "        [Description(\"The type of suppliment to feed the animals\")]",
                    "        public string SupplementType { get; set; }",
                    "",
                    "        // ============================================================",
                    "        // Called every day to perform management actions",
                    "        // ============================================================",
                    "        [EventSubscribe(\"DoManagement\")]",
                    "        private void OnDoManagement(object sender, EventArgs e)",
                    "        {",
                    "            // Determine how many animals are in feedlot.",
                    "            var animalGroupsInFeedlot = animals.AnimalGroups.Where(group => group.PaddOccupied.Name == FeedlotZone.Name);",
                    "            var totalNumAnimalsInFeedlot = animalGroupsInFeedlot.Sum(group => group.NoAnimals);",
                    "",
                    "            // If there are animals in feedlot then feed them.",
                    "            if (totalNumAnimalsInFeedlot > 0)",
                    "                supplement.Feed(SupplementType, SupplementAmount * totalNumAnimalsInFeedlot, FeedlotZone.Name);     ",
                    "",
                    "            // Restock the supplement store if amount falls below 500 kg/ha",
                    "            if (supplement.Stores[1].Stored <= 500)       ",
                    "                supplement.Buy(5000, SupplementType);",
                    "        }",
                    "    }",
                    "}"
                  ],
                  "Parameters": [
                    {
                      "Key": "FeedlotZone",
                      "Value": "[Feedlot]"
                    },
                    {
                      "Key": "SupplementAmount",
                      "Value": "0.5"
                    },
                    {
                      "Key": "SupplementType",
                      "Value": "wheat, crushed"
                    }
                  ],
                  "Name": "ManageSupplement",
                  "ResourceName": null,
                  "Children": [],
                  "Enabled": true,
                  "ReadOnly": false
                },
