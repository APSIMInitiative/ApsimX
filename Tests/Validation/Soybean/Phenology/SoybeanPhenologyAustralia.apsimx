                        "[Soybean].Phenology.NFF",
                        "[Soybean].Script.FinalTag"
                      ],
                      "EventNames": [
                        "[Soybean].Harvesting"
                      ],
                      "GroupByVariableName": null,
                      "Name": "HarvestReport",
                      "ResourceName": null,
                      "Children": [],
                      "Enabled": true,
                      "ReadOnly": false
                    },
