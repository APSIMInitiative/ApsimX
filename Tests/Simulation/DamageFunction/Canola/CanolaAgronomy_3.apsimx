                    {
                      "$type": "Models.Manager, Models",
                      "CodeArray": [
                        "using Models.Soils;",
                        "using System;",
                        "using Models.Core;",
                        "using Models.PMF;",
                        "namespace Models",
                        "{",
                        "    [Serializable]",
                        "    [System.Xml.Serialization.XmlInclude(typeof(Model))]",
                        "    public class Script : Model",
                        "    {",
                        "        [Link] Clock Clock;",
                        "",
                        "        [EventSubscribe(\"StartOfSimulation\")]",
                        "        private void OnSimulationCommencing(object sender, EventArgs e)",
                        "        {",
                        "            /*",
                        "                ",
                        "                 dateset = 0",
                        "                 emer_date = 0",
                        "                 endjuv_date = 0",
                        "                 anth_date = 0",
                        "                 mat_date = 0",
                        "                 event = 0",
                        "                 cum_temp = 0",
                        "                 cum_swdef = 0",
                        "                 cum_days = 0",
                        "            ",
                        "            */",
                        "        }",
                        "        [EventSubscribe(\"DoManagement\")]",
                        "        private void OnDoManagement(object sender, EventArgs e)",
                        "        {",
                        "            /*",
                        "                ",
                        "               if (daysaftersowing = 1) then",
                        "                  cum_temp = 0",
                        "                  cum_swdef = 0",
                        "                  cum_days = 0",
                        "               elseif (stagename = 'start_grain_fill' or",
                        "                             stagename = 'end_grain_fill' or",
                        "                             stagename = 'maturity' or",
                        "                             stagename = 'harvest_ripe') then",
                        "                  cum_temp = cum_temp + (maxt + mint) / 2",
                        "                  cum_swdef = cum_swdef + swdef_photo",
                        "                  cum_days = cum_days + 1",
                        "               endif",
                        "               ! calculate canola oil content",
                        "               if (cum_days > 0) then",
                        "                  avg_temp = cum_temp / cum_days",
                        "                  avg_swdef = cum_swdef / cum_days",
                        "                  if (avg_temp <= 14) then",
                        "                     oil_conc =  47",
                        "                  else",
                        "                     oil_conc = (47 - ((avg_temp - 14)*1.21)) - (1.91*(1 - avg_swdef^2))",
                        "                  endif",
                        "               else",
                        "                  oil_conc = 0",
                        "               endif",
                        "            if (canola.stagename = 'harvest_ripe' or canola.plant_status = 'dead') then",
                        "               canola harvest",
                        "               canola kill_crop",
                        "               canola end_crop",
                        "               dateset = 0",
                        "            endif",
                        "            ",
                        "            */",
                        "        }",
                        "    }",
                        "}"
                      ],
                      "Parameters": [],
                      "Name": "manager",
                      "ResourceName": null,
                      "Children": [],
                      "Enabled": true,
                      "ReadOnly": false
                    },
                    {
                      "$type": "Models.Manager, Models",
                      "CodeArray": [
                        "using APSIM.Shared.Utilities;",
                        "using Models.Utilities;",
                        "using Models.Soils;",
                        "using Models.PMF;",
                        "using Models.Core;",
                        "using System;",
                        "",
                        "namespace Models",
                        "{",
                        "    [Serializable]",
                        "    public class Script : Model",
                        "    {",
                        "        [Link] Clock Clock;",
                        "        [Link] Fertiliser Fertiliser;",
                        "        [Link] Summary Summary;",
                        "        [Link] Soil Soil;",
                        "        [Link] Plant Canola;",
                        "        Accumulator accumulatedRain;",
                        "        ",
                        "        [Description(\"Sowing date (d-mmm)\")]",
                        "        public string SowDate { get; set; }",
                        "        [Description(\"Cultivar to be sown\")]",
                        "        public string CultivarName { get; set; }",
                        "        [Description(\"Sowing depth (mm)\")]",
                        "        public double SowingDepth { get; set; }",
                        "        [Description(\"Row spacing (mm)\")]",
                        "        public double RowSpacing { get; set; }",
                        "        [Description(\"Plant population (/m2)\")]",
                        "        public double Population { get; set; }",
                        "        ",
                        "",
                        "",
                        "        [EventSubscribe(\"DoManagement\")]",
                        "        private void OnDoManagement(object sender, EventArgs e)",
                        "        {",
                        "            if (DateUtilities.WithinDates(SowDate, Clock.Today, SowDate))",
                        "            {",
                        "                Canola.Sow(population: Population, cultivar: CultivarName, depth: SowingDepth, rowSpacing: RowSpacing);    ",
                        "            }",
                        "        ",
                        "        }",
                        "        ",
                        "    }",
                        "}"
                      ],
                      "Parameters": [
                        {
                          "Key": "SowDate",
                          "Value": "23-Apr"
                        },
                        {
                          "Key": "CultivarName",
                          "Value": "Hyola575_CL_GT"
                        },
                        {
                          "Key": "SowingDepth",
                          "Value": "30"
                        },
                        {
                          "Key": "RowSpacing",
                          "Value": "230"
                        },
                        {
                          "Key": "Population",
                          "Value": "35"
                        }
                      ],
                      "Name": "SowingRule",
                      "ResourceName": null,
                      "Children": [],
                      "Enabled": true,
                      "ReadOnly": false
                    },
                    {
                      "$type": "Models.Manager, Models",
                      "CodeArray": [
                        "using Models.Soils;",
                        "using System;",
