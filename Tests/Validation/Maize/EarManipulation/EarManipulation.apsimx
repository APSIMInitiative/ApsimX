                                "[Maize].Leaf.ExtinctionCoeff.WaterStressImpact",
                                "[Maize].Leaf.Photosynthesis.FT",
                                "[Maize].Leaf.Photosynthesis.FN",
                                "[Maize].Phenology.FloweringDAS",
                                "[Maize].Phenology.MaturityDAS ",
                                "[Swim].WaterTable",
                                "",
                                "sum([Swim].SW[5:6])*0.5 as sw_30cm",
                                "sum([Swim].SW[7:8])*0.5 as sw_60cm",
                                "sum([Swim].SW[11:12])*0.5 as sw_120cm",
                                "[Weather].Rain",
                                "[Weather].MeanT",
                                "[Weather].MaxT",
                                "[Weather].MinT",
                                "",
                                "sum of [Field].Soil.Swim.Runoff from [Maize].Sowing to [Clock].EndOfYear as CummRunoff",
                                "sum of [Weather].Rain from [Maize].Sowing to [Clock].EndOfYear as CummRain",
                                "sum of [Maize].Leaf.Transpiration from [Maize].Sowing to [Clock].EndOfYear as CummTranspiration",
                                "sum of [Swim].Es from [Maize].Sowing to [Clock].EndOfYear as CummEvaporation",
                                "sum of [Field].Soil.Swim.Drainage from [Maize].Sowing to [Clock].EndOfYear as CummDrainage",
                                "sum([Swim].SWmm[1:10]) - sum([Field].Soil.Physical.DULmm[1:10]) as SoilWaterDeficit",
                                "sum of [Field].Irrigation.IrrigationApplied from [Maize].Sowing to [Clock].EndOfYear as CummIrrigation",
                                "CummRain + CummIrrigation as RainPlusIrrigation",
                                "[Maize].Leaf.Transpiration + [Field].Soil.Swim.Es as CropET",
                                "",
                                "sum([Field].Soil.Nutrient.NO3.kgha[1:10]) as NO3",
                                "sum([Field].Soil.NH4.kgha[1:10]) as NH4",
                                "",
                                "[SurfaceOrganicMatter].N",
                                "sum of sum([Soil].Nutrient.DenitrifiedN) from [Maize].Sowing to [Clock].EndOfYear as CummDenitrif",
                                "sum of sum([Soil].Nutrient.N2Oatm) from [Maize].Sowing to [Clock].EndOfYear as CummN2O",
                                "sum of [Fertiliser].NitrogenApplied from [Maize].Sowing to [Clock].EndOfYear as CummNfertilizer",
                                "sum of sum([Soil].Nutrient.MineralisedN + [SurfaceOrganicMatter].SurfaceResidue.Decomposition.MineralisedN) from [Maize].Sowing to [Clock].EndOfYear as CummSoilNetMineral",
                                "sum of [Soil].Swim.LeachNO3 from [Maize].Sowing to [Clock].EndOfYear as CummNleaching",
                                "sum of (-1 * [Maize].Root.NUptake) from [Maize].Sowing to [Clock].EndOfYear as CummNUptake"
                              ],
                              "EventNames": [
                                "[Clock].DoReport",
                                "//[Maize].Harvesting"
                              ],
                              "GroupByVariableName": null,
                              "Name": "Report_SWIM",
                              "ResourceName": null,
                              "Children": [],
                              "Enabled": true,
                              "ReadOnly": false
                            }
