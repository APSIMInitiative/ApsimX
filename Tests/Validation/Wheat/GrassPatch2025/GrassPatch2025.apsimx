                {
                  "$type": "Models.Manager, Models",
                  "CodeArray": [
                    "using Newtonsoft.Json;",
                    "using System.Data;",
                    "using System.Xml.Serialization;",
                    "using Models;",
                    "using System.Text;",
                    "using System.Collections.Generic;",
                    "using Models.Interfaces;",
                    "using System;",
                    "using Models.Core;",
                    "using Models.PMF;",
                    "using Models.Soils;",
                    "using Models.Utilities;",
                    "using APSIM.Shared.Utilities;",
                    "",
                    "namespace Models",
                    "{",
                    "    [Serializable]",
                    "    public class Script : Model",
                    "    {",
                    "        [Link] Clock Clock;",
                    "        [Link] Fertiliser Fertiliser;",
                    "        [Link] Summary Summary;",
                    "        [Link] Soil Soil;",
                    "        [Link] Plant Wheat;",
                    "        [Link] Simulation Simulation;",
                    "        Accumulator accumulatedRain;",
                    "        ",
                    "        [Description(\"Sowing date (d-mmm)\")]",
                    "        public string SowDate { get; set; }",
                    "        [Description(\"Treatment Name\")]",
                    "        public string Treat { get; set; }",
                    "        [Display(Type = DisplayType.CultivarName)]",
                    "        [Description(\"Cultivar to be sown\")]",
                    "        public string CultivarName { get; set; }",
                    "        [Description(\"Sowing depth (mm)\")]",
                    "        public double SowingDepth { get; set; }",
                    "        [Description(\"Row spacing (mm)\")]",
                    "        public double RowSpacing { get; set; }",
                    "        [Description(\"Plant population (/m2)\")]",
                    "        public double Population { get; set; }",
                    "",
                    "",
                    "",
                    "        [EventSubscribe(\"DoManagement\")]",
                    "        private void OnDoManagement(object sender, EventArgs e)",
                    "        {",
                    "",
                    "            if (DateUtilities.WithinDates(SowDate, Clock.Today, SowDate))",
                    "            {",
                    "               Wheat.Sow(population: Population, cultivar: CultivarName, depth: SowingDepth, rowSpacing: RowSpacing);    ",
                    "            }            ",
                    "        ",
                    "        }",
                    "        ",
                    "    }",
                    "}"
                  ],
                  "Parameters": [
                    {
                      "Key": "SowDate",
                      "Value": ""
                    },
                    {
                      "Key": "Treat",
                      "Value": ""
                    },
                    {
                      "Key": "CultivarName",
                      "Value": ""
                    },
                    {
                      "Key": "SowingDepth",
                      "Value": "30"
                    },
                    {
                      "Key": "RowSpacing",
                      "Value": "225"
                    },
                    {
                      "Key": "Population",
                      "Value": "150"
                    }
                  ],
                  "Name": "Sowing",
                  "ResourceName": null,
                  "Children": [],
                  "Enabled": true,
                  "ReadOnly": false
                },
                {
                  "$type": "Models.Manager, Models",
                  "CodeArray": [
                    "using Models.Soils;",
                    "using System;",
                    "using Models.Core;",
                    "using Models.PMF;",
                    "namespace Models",
                    "{",
                    "    [Serializable]",
                    "    public class Script : Model",
                    "    {",
                    "        [Link] Clock Clock;",
                    "        [Link] Fertiliser Fertiliser;",
                    "        [Link] Summary Summary;",
                    "        ",
                    "        ",
                    "        [Description(\"Amount of fertiliser to be applied (50:50 Urea:MAP, kg/ha)\")]",
                    "        public double Amount { get; set;}",
                    "        ",
                    "        [Description(\"Crop to be fertilised\")]",
                    "        public string CropName { get; set;}",
                    "        ",
                    "        ",
                    "        ",
                    "",
                    "        [EventSubscribe(\"Sowing\")]",
                    "        private void OnSowing(object sender, EventArgs e)",
                    "        {",
                    "            Model crop = sender as Model;",
                    "            if (crop.Name.ToLower()==CropName.ToLower())",
                    "                Fertiliser.Apply(amount: Amount*0.5, type: \"MAP\");",
                    "                Fertiliser.Apply(amount: Amount*0.5, type: \"UreaGranular\");",
                    "        }",
                    "        ",
                    "    }",
                    "}"
                  ],
                  "Parameters": [
                    {
                      "Key": "Amount",
                      "Value": "120"
                    },
                    {
                      "Key": "CropName",
                      "Value": "wheat"
                    }
                  ],
                  "Name": "SowingFertiliser",
                  "ResourceName": null,
                  "Children": [],
                  "Enabled": true,
                  "ReadOnly": false
                },
                {
                  "$type": "Models.Manager, Models",
                  "CodeArray": [
                    "using APSIM.Core;",
                    "using System;",
                    "using Models.Core;",
                    "using Models.PMF;",
                    "using Models.Soils;",
                    "using Models.Utilities;",
                    "using APSIM.Shared.Utilities;",
                    "",
                    "namespace Models",
                    "{",
                    "    [Serializable]",
                    "    public class Script : Model, IStructureDependency",
                    "    {",
                    "        [Link] private Plant Wheat;",
                    "        [Link] private Clock Clock;",
                    "        [Link] private Simulation sim;",
                    "        public IStructure Structure { private get; set; }",
                    "",
                    "",
                    "        ",
                    "",
                    "        [EventSubscribe(\"DoManagement\")]",
                    "        private void OnDoManagement(object sender, EventArgs e)",
                    "        {",
                    "            if (Wheat.IsReadyForHarvesting)",
                    "            {",
                    "               Wheat.Harvest();",
                    "               Wheat.EndCrop();  ",
                    "               Structure.Set(\"Clock.EndDate\", Clock.Today.AddDays(1), relativeTo: sim);  ",
                    "            }",
                    "        ",
                    "        }",
                    "        ",
                    "    }",
                    "}"
                  ],
                  "Parameters": [],
                  "Name": "Harvesting",
                  "ResourceName": null,
                  "Children": [],
                  "Enabled": true,
                  "ReadOnly": false
                },
