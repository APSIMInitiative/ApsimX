                        "    public class Script : Model",
                        "    {",
                        "        [Link] ISummary summary;",
                        "        [Link] private Plant canola;",
                        "        [Link(Type = LinkType.Path, Path = \"[canola].Phenology\")]",
                        "        private Phenology phenology;",
                        "                [Link] Clock Clock;",
                        "",
                        "        private bool Harvestable = false;",
                        "",
                        "        [Description(\"Harvest Date (d-mmm)\")]",
                        "        public string HarvestDate { get; set; }   ",
                        "      ",
                        "        [EventSubscribe(\"DoManagement\")]",
                        "        private void OnDoManagement(object sender, EventArgs e)",
                        "        {",
                        "           ",
                        "            if (Harvestable && phenology.CurrentPhase.Name == \"ReadyForHarvesting\")",
                        "            {",
                        "                canola.Harvest();",
                        "                canola.EndCrop();                ",
                        "            }",
                        "            ",
                        "            if (DateUtilities.DatesAreEqual(HarvestDate, Clock.Today))",
                        "                Harvestable = true;",
                        "",
                        "        }",
                        "    }",
                        "}",
                        "       "
                      ],
                      "Parameters": [
                        {
                          "Key": "HarvestDate",
                          "Value": "23-Oct"
