    {
      "$type": "Models.Core.Folder, Models",
      "ShowInDocs": false,
      "Name": "Replacements",
      "ResourceName": null,
      "Children": [
        {
          "$type": "Models.Manager, Models",
          "CodeArray": [
            "using APSIM.Core;",
            "using Models.Soils.Nutrients;",
            "using System;",
            "using Models.Core;",
            "using System.Collections.Generic;",
            "using System.Text;",
            "using Models.Soils;",
            "using Models.PMF;",
            "using Models;",
            "using System.Xml.Serialization;",
            "using APSIM.Shared.Utilities;",
            "",
            "namespace Models",
            "{",
            "    [Serializable] ",
            "    public class Script : Model, IStructureDependency",
            "    {",
            "        [Link] private Plant Wheat;",
            "        [Link] private Simulation sim;",
            "        [Link] private Clock clock;",
            "",
            "        // 1. Expose the date to the APSIM UI. ",
            "        // This will create a clean input box in the interface.",
            "        [Description(\"Target Harvest Date (e.g., 2025-11-27):\")]",
            "        public DateTime TargetHarvestDate { get; set; }",
            "",
            "        public IStructure Structure { private get; set; }",
            "",
            "        [EventSubscribe(\"DoManagement\")]",
            "        private void OnDoManagement(object sender, EventArgs e)",
            "        {",
            "            // 2. Trigger harvest ONLY when the calendar date matches exactly, ",
            "            // AND ensure the crop is actually growing to prevent errors.",
            "            if (clock.Today == TargetHarvestDate && Wheat.IsAlive)",
            "            {",
            "                Wheat.Harvest();",
            "                Wheat.EndCrop();",
            "                ",
            "                // Forces the simulation to end on this harvest date",
            "                Structure.Set(\"Clock.EndDate\", clock.Today, relativeTo: sim);  ",
            "            }",
            "        }",
            "",
            "        [EventSubscribe(\"EndOfDay\")]",
            "        private void OnEndOfDay(object sender, EventArgs e)",
            "        {",
            "            // 3. Fallback safety net: if the simulation reaches its set EndDate ",
            "            // for any other reason before the TargetHarvestDate, clean up the crop.",
            "            if ((clock.Today.Equals(clock.EndDate)) && (Wheat.IsAlive))",
            "            {",
            "                Wheat.Harvest();",
            "                Wheat.EndCrop();",
            "            }",
            "        }",
            "    }",
            "}"
          ],
          "Parameters": [
            {
              "Key": "TargetHarvestDate",
              "Value": "01/06/2026 00:00:00"
            }
          ],
          "Name": "Harvesting",
          "ResourceName": null,
          "Children": [],
          "Enabled": true,
          "ReadOnly": false
        },
