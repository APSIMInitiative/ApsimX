                  "Children": [],
                  "IncludeInDocumentation": true,
                  "Enabled": true,
                  "ReadOnly": false
                },
                {
                  "$type": "Models.Memo, Models",
                  "Text": "\nEccelE, 2012 Meteorol. Appl. 19: 118–128 (2012) p.120: \n\nRelative humidity can be expressed as the ratio between actual water vapour and saturation vapour, which is, in turn, a pure function of temperature:\n\nRH = 100*(e/es)\n\nwhere e = actual water vapour pressure \n\nand   es=  saturation water vapour pressure.",
                  "Name": "Memo",
                  "Children": [],
                  "IncludeInDocumentation": true,
                  "Enabled": true,
                  "ReadOnly": false
                }
