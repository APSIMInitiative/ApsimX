        {
          "$type": "Models.Manager, Models",
          "CodeArray": [
            "using APSIM.Core;",
            "using Models.Soils.Nutrients;",
            "using System;",
            "using Models.Core;",
            "using System.Collections.Generic;",
            "using System.Text;",
            "using Models.Soils;",
            "using Models.PMF;",
            "using Models;",
            "using System.Xml.Serialization;",
            "using APSIM.Shared.Utilities;",
            "using Models.PMF.Phen;",
            "",
            "namespace Models",
            "{",
            "    [Serializable] ",
            "    public class Script : Model, IStructureDependency",
            "    {",
            "        [Link] private Plant Wheat;",
            "        [Link] private Simulation sim;",
            "        [Link] private Clock clock;",
            "        [Link(Type = LinkType.Path, Path = \"[Wheat].Phenology\")]",
            "        private Phenology phenology;",
            "        public IStructure Structure { private get; set; }",
            "",
            "",
            "        ",
            "",
            "        [EventSubscribe(\"DoManagement\")]",
            "        private void OnDoManagement(object sender, EventArgs e)",
            "        {",
            "            if (phenology.CurrentPhase.Name == \"GrainRipening\")",
            "            {",
            "                Wheat.Harvest();",
            "                Wheat.EndCrop();",
            "                Structure.Set(\"Clock.EndDate\", clock.Today, relativeTo: sim);  ",
            "            }",
            "        }",
            "",
            "        [EventSubscribe(\"EndOfDay\")]",
            "        private void OnEndOfDay(object sender, EventArgs e)",
            "        {",
            "            if ((clock.Today.Equals(clock.EndDate))&&(Wheat.IsAlive))",
            "            {",
            "                Wheat.Harvest();",
            "                Wheat.EndCrop();",
            "                Structure.Set(\"Clock.EndDate\", clock.Today, relativeTo: sim);  ",
            "            }",
            "        }",
            "",
            "    }",
            "}",
            "       "
          ],
          "Parameters": [],
          "Name": "Harvesting",
          "ResourceName": null,
          "Children": [],
          "Enabled": true,
          "ReadOnly": false
        },
