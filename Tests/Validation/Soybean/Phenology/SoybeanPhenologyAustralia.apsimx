                    {
                      "$type": "Models.Manager, Models",
                      "CodeArray": [
                        "",
                        "using Models.Soils;",
                        "using System;",
                        "using Models.Core;",
                        "using Models.PMF;",
                        "using APSIM.Shared.Utilities;",
                        "        ",
                        "        namespace Models",
                        "        {",
                        "           [Serializable] ",
                        "           [System.Xml.Serialization.XmlInclude(typeof(Model))]",
                        "            public class Script : Model",
                        "            {      ",
                        "               [Link] Plant Soybean;",
                        "               [Link] Clock Clock;",
                        "",
                        "               [Description(\"Spacing (mm) between rows\")]",
                        "               public double RowSpacing { get; set; }",
                        "               [Description(\"Depth (mm) Grains are planted\")]",
                        "               public double SowingDepth { get; set; }",
                        "               [Description(\"Seeds sown (/m2)\")]",
                        "               public double SowingRate { get; set; }",
                        "               [Description(\"Cultivar\")]",
                        "               [Display(Type=DisplayType.CultivarName)]",
                        "               public string CultivarName { get; set; }",
                        "               [Description(\"Sowing Date\")]",
                        "               public DateTime SowingDate { get; set; }",
                        "",
                        "               [EventSubscribe(\"DoManagement\")]",
                        "               private void OnDoManagement(object sender, EventArgs e)",
                        "               {",
                        "                if (Clock.Today.Date == SowingDate)",
                        "                    Soybean.Sow(population:SowingRate, cultivar:CultivarName, depth:SowingDepth, rowSpacing:RowSpacing, budNumber:1);",
                        "               }",
                        "            }",
                        "        }",
                        "                "
                      ],
                      "Parameters": [
                        {
                          "Key": "RowSpacing",
                          "Value": "850"
                        },
                        {
                          "Key": "SowingDepth",
                          "Value": "50"
                        },
                        {
                          "Key": "SowingRate",
                          "Value": "30"
                        },
                        {
                          "Key": "CultivarName",
                          "Value": "Bidgee"
                        },
                        {
                          "Key": "SowingDate",
                          "Value": "12/23/2013 00:00:00"
                        }
                      ],
                      "Name": "SowingRule",
                      "ResourceName": null,
                      "Children": [],
                      "Enabled": true,
                      "ReadOnly": false
                    },
                    {
                      "$type": "Models.Manager, Models",
                      "CodeArray": [
                        "using APSIM.Core;",
                        "using APSIM.Shared.Utilities;",
                        "using System.Xml.Serialization;",
                        "using Models.Functions;",
                        "using Models;",
                        "using Models.PMF;",
                        "using Models.Soils;",
                        "using System.Text;",
                        "using System.Collections.Generic;",
                        "using Models.Core;",
                        "using System;",
                        "using Models.Soils.Nutrients;",
                        " ",
                        "namespace Models",
                        "{",
                        "    [Serializable]",
                        "    public class Script : Model, IStructureDependency",
                        "    {     ",
                        "        [Link] private Plant Soybean;",
                        "        [Link] private Clock Clock;",
                        "        ",
                        "        public IStructure Structure { private get; set; }",
                        "",
                        "        public double NodeNumber {get; set;} = 0;",
                        "    ",
                        "        [Description(\"Harvest Date\")]",
                        "        public DateTime HarvestDate { get; set; }",
                        "     ",
                        "     ",
                        "        [EventSubscribe(\"DoManagement\")]",
                        "        private void OnDoManagement(object sender, EventArgs e)",
                        "        {",
                        "           if (Clock.Today.Date == HarvestDate)",
                        "           {",
                        "            NodeNumber = (  Structure.FindChild<IModel>(\"NodeNumber\", relativeTo: (INodeModel)(Soybean.Leaf as IModel)) as IFunction).Value();",
                        "            Soybean.Harvest();",
                        "            Soybean.EndCrop();",
                        "           }",
                        "        }",
                        "    }",
                        "}"
                      ],
                      "Parameters": [
                        {
                          "Key": "HarvestDate",
                          "Value": "04/23/2014 00:00:00"
                        }
                      ],
                      "Name": "HarvestRule",
                      "ResourceName": null,
                      "Children": [],
                      "Enabled": true,
                      "ReadOnly": false
                    },
