                    {
                      "$type": "Models.Manager, Models",
                      "CodeArray": [
                        "using Models.Soils;",
                        "using System;",
                        "using Models.Core;",
                        "using Models.PMF;",
                        "namespace Models",
                        "{",
                        "    [Serializable]",
                        "    [System.Xml.Serialization.XmlInclude(typeof(Model))]",
