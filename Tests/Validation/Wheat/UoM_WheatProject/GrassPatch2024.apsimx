                    }
                  ],
                  "Name": "Sowing",
                  "ResourceName": null,
                  "Children": [],
                  "Enabled": true,
                  "ReadOnly": false
                },
                {
                  "$type": "Models.Manager, Models",
                  "CodeArray": [
                    "using Models.Soils;",
                    "using System;",
                    "using Models.Core;",
                    "using Models.PMF;",
                    "namespace Models",
                    "{",
                    "    [Serializable]",
                    "    public class Script : Model",
                    "    {",
                    "        [Link] Clock Clock;",
                    "        [Link] Fertiliser Fertiliser;",
                    "        [Link] Summary Summary;",
                    "        ",
                    "        ",
                    "        [Description(\"Amount of fertiliser to be applied (50:50 Urea:MAP, kg/ha)\")]",
                    "        public double Amount { get; set;}",
                    "        ",
                    "        [Description(\"Crop to be fertilised\")]",
                    "        public string CropName { get; set;}",
                    "        ",
                    "        ",
                    "        ",
                    "",
                    "        [EventSubscribe(\"Sowing\")]",
                    "        private void OnSowing(object sender, EventArgs e)",
                    "        {",
                    "            Model crop = sender as Model;",
                    "            if (crop.Name.ToLower()==CropName.ToLower())",
                    "                Fertiliser.Apply(amount: Amount*0.5, type: \"MAP\");",
                    "                Fertiliser.Apply(amount: Amount*0.5, type: \"UreaGranular\");",
                    "        }",
                    "        ",
                    "    }",
                    "}"
                  ],
                  "Parameters": [
                    {
                      "Key": "Amount",
                      "Value": "120"
                    },
                    {
                      "Key": "CropName",
                      "Value": "wheat"
                    }
                  ],
                  "Name": "SowingFertiliser",
                  "ResourceName": null,
                  "Children": [],
                  "Enabled": true,
                  "ReadOnly": false
                },
                {
                  "$type": "Models.Manager, Models",
                  "CodeArray": [
                    "using APSIM.Core;",
                    "using System;",
                    "using Models.Core;",
                    "using Models.PMF;",
                    "using Models.Soils;",
                    "using Models.Utilities;",
                    "using APSIM.Shared.Utilities;",
                    "",
                    "namespace Models",
                    "{",
                    "    [Serializable]",
                    "    public class Script : Model, IStructureDependency",
                    "    {",
                    "        [Link] private Plant Wheat;",
                    "        [Link] private Clock Clock;",
                    "        [Link] private Simulation sim;",
                    "        public IStructure Structure { private get; set; }",
                    "",
                    "",
                    "        ",
                    "",
                    "        [EventSubscribe(\"DoManagement\")]",
                    "        private void OnDoManagement(object sender, EventArgs e)",
                    "        {",
                    "            if (Wheat.IsReadyForHarvesting)",
                    "            {",
                    "               Wheat.Harvest();",
                    "               Wheat.EndCrop();  ",
                    "               Structure.Set(\"Clock.EndDate\", Clock.Today.AddDays(1), relativeTo: sim);  ",
                    "            }",
                    "        ",
                    "        }",
                    "        ",
                    "    }",
                    "}"
                  ],
                  "Parameters": [],
                  "Name": "Harvesting",
                  "ResourceName": null,
                  "Children": [],
                  "Enabled": true,
                  "ReadOnly": false
                },
                {
                  "$type": "Models.Operations, Models",
                  "OperationsList": [],
                  "Name": "Management",
                  "ResourceName": null,
                  "Children": [],
                  "Enabled": true,
                  "ReadOnly": false
                },
                {
                  "$type": "Models.Irrigation, Models",
                  "Name": "Irrigation",
                  "ResourceName": null,
                  "Children": [],
                  "Enabled": true,
                  "ReadOnly": false
                },
                {
                  "$type": "Models.Manager, Models",
                  "CodeArray": [
                    "using System;",
                    "using Models.Core;",
                    "using Models.Interfaces;",
                    "using Models.PMF;",
                    "using APSIM.Shared.Utilities;",
                    "using Models.WaterModel;",
                    "",
                    "namespace Models",
                    "{",
                    "    [Serializable]",
                    "    public class Script : Model",
                    "    {",
                    "        [Link] IClock Clock;",
                    "        [Link] ISummary Summary;",
                    "        [Link] ICanopy WheatCanopy;",
                    "        [Link] EvaporationModel EvapModel;",
                    "        ",
                    "        [Description(\"Dry soil NDVI\")]",
                    "        public double DrySoilNDVI { get; set; }",
                    "        ",
                    "        [Description(\"Wet soil NDVI\")]",
                    "        public double WetSoilNDVI { get; set; }",
                    "",
                    "        [Description(\"Green Crop NDVI\")]",
                    "        public double GreenCropNDVI { get; set; }",
                    "        ",
                    "        [Description(\"Dead Crop NDVI\")]",
                    "        public double DeadCropNDVI { get; set; }",
                    "                ",
                    "        [Description(\"Daily Estimated NDVI\")]",
                    "        public double NDVI { get; set; }",
                    "",
                    "        [EventSubscribe(\"DoManagement\")]",
                    "        private void DoDailyCalculations(object sender, EventArgs e)",
                    "        {",
                    "            double SoilNDVI = WetSoilNDVI;",
                    "            if (EvapModel.t > 1)",
                    "               SoilNDVI = DrySoilNDVI;",
                    "",
                    "            NDVI = GreenCropNDVI * WheatCanopy.CoverGreen;",
                    "            NDVI += DeadCropNDVI * (WheatCanopy.CoverTotal - WheatCanopy.CoverGreen);",
                    "            NDVI += SoilNDVI * (1 - WheatCanopy.CoverTotal);            ",
                    "            ",
                    "        }",
                    "    }",
                    "}",
                    ""
                  ],
                  "Parameters": [
                    {
                      "Key": "DrySoilNDVI",
                      "Value": "0.1"
                    },
                    {
                      "Key": "WetSoilNDVI",
                      "Value": "0.12"
                    },
                    {
                      "Key": "GreenCropNDVI",
                      "Value": "0.85"
                    },
                    {
                      "Key": "DeadCropNDVI",
                      "Value": "0.1"
                    },
                    {
                      "Key": "NDVI",
                      "Value": "0"
                    }
                  ],
