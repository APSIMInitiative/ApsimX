                            "",
                            "namespace Models",
                            "{",
                            "    [Serializable] ",
                            "    //[System.Xml.Serialization.XmlInclude(typeof(Model))]",
                            "    public class Script : Model, IStructureDependency",
                            "    {",
                            "        [Link] private Clock clock;",
                            "        [Link] private Zone zone;",
                            "        [Link] private Simulation Simulation;",
                            "        public IStructure Structure { private get; set; }",
                            "        ",
                            "        [Description(\"Grain Number to set per cob\")]",
                            "        public  double GrainNum { get; set; }",
                            "        [Description(\"Is grain number set ?\")]",
                            "        public bool SetGrainNum { get; set; }",
                            "           ",
                            "",
                            "        ",
                            "",
                            "        [EventSubscribe(\"StartOfDay\")]",
                            "        private void OnStartOfDay(object sender, EventArgs e)",
                            "        {",
                            "            if (clock.Today == DateTime.Parse(\"1/11/2021\"));",
                            "            {",
                            "                if (SetGrainNum)",
                            "                {",
                            "                    object GrainNumValue = GrainNum;",
                            "                    Structure.Set(\"Maize.Grain.MaximumGrainsPerCob.FixedValue\", GrainNumValue, relativeTo: zone);  ",
                            "                }",
                            "            }",
                            "        }",
                            "    }",
                            "}",
                            "                "
                          ],
