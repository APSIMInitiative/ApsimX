                        {
                          "$type": "Models.Manager, Models",
                          "CodeArray": [
                            "using APSIM.Core;",
                            "using APSIM.Shared.Utilities;",
                            "using Models.PMF.Interfaces;",
                            "using Models.PMF;",
                            "using Models.Interfaces;",
                            "using Models.Core;",
                            "using System;",
                            "",
                            "namespace Models;",
                            "",
                            "[Serializable]",
                            "public class Script : Model, IStructureDependency",
                            "{",
                            "        [Link] private IClock Clock;",
                            "        [Link] private ISummary Summary;",
                            "        private IHasDamageableBiomass theOrgan;",
                            "        ",
                            "        public IStructure Structure { private get; set; }",
                            "    ",
                            "    [Description(\"What crop.\")]",
                            "    public IPlant TargetPlant { get; set; }",
                            "    ",
                            "    [Description(\"Remove what Organ?\")]",
                            "    public string Organ { get; set; }",
                            "    ",
                            "    [Description(\"Removal amount.\")]",
                            "    public double ToRemove { get; set; }",
                            "    ",
                            "    [Description(\"Date to remove on (dd-mmm).\")]",
                            "    public string Date { get; set; }",
                            "    ",
                            "    [EventSubscribe(\"StartOfSimulation\")]",
                            "    private void OnStartOfSimulation(object sender, EventArgs e)",
                            "    {",
                            "            theOrgan =   Structure.FindChild<IHasDamageableBiomass>(Organ, relativeTo: (INodeModel)TargetPlant);",
                            "            if (theOrgan is null)",
                            "                throw new Exception(\"Could not link organ!\");",
                            "    }",
                            "    ",
                            "    [EventSubscribe(\"DoManagement\")]",
                            "    private void DoDailyCalculations(object sender, EventArgs e)",
                            "    {",
                            "        if (DateUtilities.DatesAreEqual(Date, Clock.Today))",
                            "        {",
                            "            theOrgan.RemoveBiomass(liveToRemove: 0.0, ",
                            "                                   deadToRemove: 0.0, ",
                            "                                   liveToResidue: ToRemove, ",
                            "                                   deadToResidue: ToRemove);",
                            "        }",
                            "    }",
                            "}",
                            ""
                          ],
                          "Parameters": [
                            {
                              "Key": "TargetPlant",
                              "Value": "[Maize]"
                            },
                            {
                              "Key": "Organ",
                              "Value": "Leaf"
                            },
                            {
                              "Key": "ToRemove",
                              "Value": "1"
                            },
                            {
                              "Key": "Date",
                              "Value": "24-Jan"
                            }
                          ],
                          "Name": "RemoveStuff",
                          "ResourceName": null,
                          "Children": [],
                          "Enabled": true,
                          "ReadOnly": false
                        },
