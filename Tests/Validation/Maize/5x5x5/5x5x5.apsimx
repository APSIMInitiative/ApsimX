                            "[Maize].AboveGround.Wt",
                            "[Maize].AboveGround.N",
                            "",
                            "[Maize].Leaf.Wt",
                            "[Maize].Stem.Wt",
                            "[Maize].Cob.Wt",
                            "",
                            "[Maize].Cob.Wt + [Maize].Grain.Wt as GrainandCob",
                            "[Maize].Husk.Wt as OtherWt",
                            "",
                            "[Maize].Leaf.AppearedCohortNo",
